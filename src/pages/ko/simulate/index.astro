---
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/index';

const t = useTranslations('ko');
---

<Layout title={t('meta.builder_title')} description={t('meta.builder_desc')}>
  <!-- Onboarding header -->
  <section id="simulator-onboarding" class="py-6 md:py-8">
    <div class="max-w-[1400px] mx-auto px-4">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-4">
        <div>
          <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('simulate.tag')}</p>
          <h1 class="text-2xl md:text-3xl font-bold">
            {t('simulate.title1')} <span class="text-[--color-accent]">{t('simulate.title2')}</span>
          </h1>
          <p class="text-[--color-text-muted] text-sm mt-2 max-w-2xl">{t('simulate.desc')}</p>
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <a href="/ko/simulate?preset=bb-squeeze-short"
             class="inline-flex items-center gap-2 bg-[--color-accent] text-[--color-bg] px-4 py-2 rounded font-semibold text-sm hover:bg-[--color-accent-dim]"
             title="검증됨 = 549개+ 코인, 2년+ 실제 시장 데이터 백테스트">
            BB Squeeze 체험 (검증됨) &rarr;
          </a>
          <a href="/ko/strategies"
             class="inline-flex items-center gap-2 border border-[--color-border] text-[--color-text-muted] px-4 py-2 rounded text-sm hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
            전체 전략
          </a>
        </div>
      </div>

      <!-- 3-step onboarding guide -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4">
        <div class="flex items-center gap-3 border border-[--color-border] rounded-lg px-4 py-3 bg-[--color-bg-card]">
          <span class="font-mono text-[--color-accent] text-lg font-bold shrink-0">1</span>
          <div>
            <p class="text-sm font-semibold">프리셋 선택 또는 지표 선택</p>
            <p class="text-xs text-[--color-text-muted]">11개 이상 지표, AND/OR 논리</p>
          </div>
        </div>
        <div class="flex items-center gap-3 border border-[--color-border] rounded-lg px-4 py-3 bg-[--color-bg-card]">
          <span class="font-mono text-[--color-accent] text-lg font-bold shrink-0">2</span>
          <div>
            <p class="text-sm font-semibold">진입 조건 및 리스크 설정</p>
            <p class="text-xs text-[--color-text-muted]">손절, 익절, 시간 필터, 포지션 사이즈</p>
          </div>
        </div>
        <div class="flex items-center gap-3 border border-[--color-border] rounded-lg px-4 py-3 bg-[--color-bg-card]">
          <span class="font-mono text-[--color-accent] text-lg font-bold shrink-0">3</span>
          <div>
            <p class="text-sm font-semibold">549+ 코인에서 백테스트 실행</p>
            <p class="text-xs text-[--color-text-muted]">수초 내 결과, 수수료 포함</p>
          </div>
        </div>
      </div>

      <p class="text-xs text-[--color-text-muted] opacity-70">{t('simulate.note')}</p>
    </div>
  </section>

  <!-- Risk Disclaimer -->
  <div class="max-w-[1400px] mx-auto px-4 mb-4">
    <p class="text-xs text-gray-500 leading-relaxed">
      시뮬레이션 전용 &mdash; 실제 거래가 아닙니다. 과거 성과는 미래 결과를 보장하지 않습니다. 선물 거래는 원금 손실 위험이 있습니다.
    </p>
  </div>

  <section class="pb-4 md:pb-6">
    <div id="simulator-mount">
      <div class="max-w-[1400px] mx-auto px-4">
        <div class="border border-[--color-border] rounded-xl p-8 bg-[--color-bg-card]">
          <div class="animate-pulse space-y-4">
            <div class="h-6 bg-[--color-bg-hover] rounded w-1/3"></div>
            <div class="flex gap-4">
              <div class="w-[70%] h-[400px] bg-[--color-bg-hover] rounded"></div>
              <div class="w-[30%] space-y-3">
                <div class="h-8 bg-[--color-bg-hover] rounded"></div>
                <div class="h-8 bg-[--color-bg-hover] rounded"></div>
                <div class="h-8 bg-[--color-bg-hover] rounded"></div>
                <div class="h-8 bg-[--color-bg-hover] rounded"></div>
              </div>
            </div>
          </div>
          <div class="spinner mx-auto mb-4 mt-4"></div>
          <p class="text-[--color-text-muted] text-sm text-center">{t('simulate.loading')}</p>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { h, render } from 'preact';
    import SimulatorPage from '../../../components/SimulatorPage';
    import ErrorBoundary from '../../../components/ErrorBoundary';

    const mount = document.getElementById('simulator-mount');
    if (mount) {
      render(h(ErrorBoundary, { name: 'Simulator' }, h(SimulatorPage, { lang: 'ko' })), mount);
    }
  </script>
</Layout>
