---
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/index';

const t = useTranslations('ko');
---

<Layout title={t('meta.builder_title')} description={t('meta.builder_desc')}>

  <!-- HERO -->
  <section class="py-12 md:py-16">
    <div class="max-w-5xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">전략 시뮬레이터</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">
        만들고. 테스트하고. <span class="text-[--color-accent]">검증하세요.</span>
      </h1>
      <p class="text-[--color-text-muted] text-lg mb-6 max-w-2xl">
        {t('simulate.desc')}
      </p>
      <div class="flex flex-wrap gap-4 text-sm text-[--color-text-muted]">
        <span class="flex items-center gap-1.5"><span class="text-[--color-accent]">&#10003;</span> 코드 불필요</span>
        <span class="flex items-center gap-1.5"><span class="text-[--color-accent]">&#10003;</span> 535+ 코인, 2년+ 데이터</span>
        <span class="flex items-center gap-1.5"><span class="text-[--color-accent]">&#10003;</span> 실제 수수료 & 슬리피지</span>
      </div>
    </div>
  </section>

  <!-- STRATEGY BUILDER -->
  <section class="pb-12 border-t border-[--color-border] pt-8">
    <div class="max-w-5xl mx-auto px-4">
      <div id="builder-mount">
        <div class="border border-[--color-border] rounded-xl p-8 bg-[--color-bg-card]">
          <div class="animate-pulse space-y-4">
            <div class="h-6 bg-[--color-bg-hover] rounded w-1/2"></div>
            <div class="grid grid-cols-2 gap-4">
              <div class="h-10 bg-[--color-bg-hover] rounded"></div>
              <div class="h-10 bg-[--color-bg-hover] rounded"></div>
            </div>
            <div class="h-40 bg-[--color-bg-hover] rounded"></div>
          </div>
          <div class="spinner mx-auto mb-4 mt-4"></div>
          <p class="text-[--color-text-muted] text-sm text-center">{t('simulate.loading')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- OOS VALIDATION -->
  <section class="pb-12 border-t border-[--color-border] pt-8">
    <div class="max-w-5xl mx-auto px-4">
      <div id="oos-mount"></div>
    </div>
  </section>

  <!-- TESTED STRATEGIES -->
  <section class="pb-12 border-t border-[--color-border] pt-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-2">{t('simulate.strategies_title')}</h2>
      <p class="text-[--color-text-muted] text-sm mb-6">
        {t('simulate.strategies_desc')}
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <!-- BB Squeeze SHORT: Hero card spanning 2 cols -->
        <a href="/ko/strategies/bb-squeeze-short" class="md:col-span-2 border-2 border-[--color-accent]/30 rounded-lg p-6 bg-[--color-bg-card] card-hover block hover:border-[--color-accent]/60 transition-colors">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-green-500/10 text-green-400 border border-green-500/20">{t('strategy.verified')}</span>
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-[--color-accent]/10 text-[--color-accent] border border-[--color-accent]/20">LIVE</span>
          </div>
          <h3 class="font-bold text-lg mb-1">BB Squeeze SHORT</h3>
          <p class="text-[--color-text-muted] text-sm mb-4">{t('simulate.strategy_desc_bb_short')}</p>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm">
            <div><span class="text-[--color-text-muted] text-xs block">{t('strategy.win_rate')}</span> <span class="font-mono font-bold text-[--color-accent] text-lg">68.6%</span></div>
            <div><span class="text-[--color-text-muted] text-xs block">{t('strategy.profit_factor')}</span> <span class="font-mono font-bold text-[--color-accent] text-lg">2.22</span></div>
            <div><span class="text-[--color-text-muted] text-xs block">{t('compare.trades')}</span> <span class="font-mono text-lg">2,898</span></div>
            <div><span class="text-[--color-text-muted] text-xs block">{t('strategy.total_pnl')}</span> <span class="font-mono font-bold text-green-400 text-lg">+$794</span></div>
          </div>
        </a>

        <!-- Killed strategies: compact stack -->
        <div class="space-y-4">
          <a href="/ko/strategies/bb-squeeze-long" class="border border-[--color-border] rounded-lg p-4 bg-[--color-bg-card] card-hover block opacity-60 hover:opacity-80 transition-opacity">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-xs font-mono px-2 py-0.5 rounded bg-[--color-red]/10 text-[--color-text] border border-[--color-red]/20">{t('strategy.killed')}</span>
            </div>
            <h3 class="font-bold text-sm mb-1">BB Squeeze LONG</h3>
            <div class="flex gap-4 text-xs">
              <span class="text-[--color-text-muted]">WR <span class="font-mono">51%</span></span>
              <span class="text-[--color-text-muted]">PF <span class="font-mono">0.98</span></span>
              <span class="font-mono px-1 py-0.5 rounded bg-[--color-red]/10 text-[--color-text]">-$26</span>
            </div>
          </a>

          <a href="/ko/strategies/momentum-long" class="border border-[--color-border] rounded-lg p-4 bg-[--color-bg-card] card-hover block opacity-60 hover:opacity-80 transition-opacity">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-xs font-mono px-2 py-0.5 rounded bg-[--color-red]/10 text-[--color-text] border border-[--color-red]/20">{t('strategy.killed')}</span>
            </div>
            <h3 class="font-bold text-sm mb-1">Momentum Breakout LONG</h3>
            <div class="flex gap-4 text-xs">
              <span class="text-[--color-text-muted]">WR <span class="font-mono">37.5%</span></span>
              <span class="text-[--color-text-muted]">PF <span class="font-mono">0.42</span></span>
              <span class="font-mono px-1 py-0.5 rounded bg-[--color-red]/10 text-[--color-text]">-$14,115</span>
            </div>
          </a>
        </div>
      </div>

      <div class="mt-4 text-center">
        <a href="/ko/strategies" class="text-sm text-[--color-text-muted] hover:text-[--color-accent] transition-colors">
          {t('simulate.view_all')} &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- DISCLAIMER -->
  <section class="pb-16 bg-[--color-bg-subtle]">
    <div class="max-w-5xl mx-auto px-4 text-center pt-12">
      <p class="text-[--color-text-muted] text-xs max-w-lg mx-auto">
        {t('simulate.disclaimer')}
      </p>
    </div>
  </section>

</Layout>

<script>
  import { h, render } from 'preact';
  import StrategyBuilder from '../../../components/StrategyBuilder';
  import OOSValidation from '../../../components/OOSValidation';
  import ErrorBoundary from '../../../components/ErrorBoundary';

  const mount = document.getElementById('builder-mount');
  if (mount) {
    render(h(ErrorBoundary, { name: 'Strategy Builder' }, h(StrategyBuilder, { lang: 'ko' })), mount);
  }

  const oosMount = document.getElementById('oos-mount');
  if (oosMount) {
    render(h(ErrorBoundary, { name: 'OOS Validation' }, h(OOSValidation, { lang: 'ko' })), oosMount);
  }
</script>
