          Affiliate disclosure: PRUVIQ earns a commission when you sign up through our referral links.
          Your fee discounts are not affected.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 border-t border-[--color-border]">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <p class="font-mono text-[--color-text-muted] text-sm mb-4 tracking-wider">DON'T BELIEVE. VERIFY.</p>
      <h2 class="text-3xl md:text-5xl font-bold mb-4">
