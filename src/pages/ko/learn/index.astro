---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/index';
import LearnProgress from '../../../components/LearnProgress.tsx';
import LearnCard from '../../../components/LearnCard.tsx';

const t = useTranslations('ko');

// Get both Korean and English posts
const koPosts = await getCollection('blog-ko');
const enPosts = await getCollection('blog');
const koIds = new Set(koPosts.map(p => p.id));

// Combine: Korean posts + English posts without Korean version
const allPosts = [
  ...koPosts.map(p => ({ ...p, isKorean: true })),
  ...enPosts.filter(p => !koIds.has(p.id)).map(p => ({ ...p, isKorean: false })),
].sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Group by level
const beginner = allPosts.filter(p =>
  p.data.tags?.includes('beginners') ||
  p.id === 'how-to-backtest-crypto-strategy' ||
  p.id === 'what-is-bb-squeeze' ||
  p.id === 'risk-management-101' ||
  p.id === 'why-pruviq' ||
  p.id === 'crypto-trading-fees-explained'
);

const intermediate = allPosts.filter(p =>
  ['rsi-oversold-overbought-guide', 'ema-crossover-strategy-guide', 'macd-divergence-trading-guide',
   'volume-analysis-crypto-trading', 'stochastic-adx-trend-strength', 'sl-tp-optimization-guide',
   'save-on-binance-futures-fees', 'ichimoku-cloud-trading-guide', 'fibonacci-retracement-guide',
   'vwap-trading-guide', 'support-resistance-guide', 'candlestick-patterns-guide',
   'atr-volatility-guide'].includes(p.id)
);

const advanced = allPosts.filter(p =>
  p.data.category === 'quant' ||
  p.data.category === 'market' ||
  ['tp8-decision-process'].includes(p.id)
);

// Tag translation map (EN → KO) from i18n
const tagMap: Record<string, string> = {
  'beginners': t('learn.tag_beginners'), 'futures': t('learn.tag_futures'), 'leverage': t('learn.tag_leverage'),
  'perpetual-contracts': t('learn.tag_perpetual_contracts'), 'bollinger-bands': t('learn.tag_bollinger_bands'),
  'squeeze': t('learn.tag_squeeze'), 'volatility': t('learn.tag_volatility'), 'risk-management': t('learn.tag_risk_management'),
  'position-sizing': t('learn.tag_position_sizing'), 'stop-loss': t('learn.tag_stop_loss'), 'take-profit': t('learn.tag_take_profit'),
  'backtesting': t('learn.tag_backtesting'), 'overfitting': t('learn.tag_overfitting'), 'look-ahead-bias': t('learn.tag_look_ahead_bias'),
  'rsi': t('learn.tag_rsi'), 'ema': t('learn.tag_ema'), 'macd': t('learn.tag_macd'), 'atr': t('learn.tag_atr'), 'vwap': t('learn.tag_vwap'),
  'adx': t('learn.tag_adx'), 'indicators': t('learn.tag_indicators'), 'momentum': t('learn.tag_momentum'),
  'oversold': t('learn.tag_oversold'), 'overbought': t('learn.tag_overbought'), 'mean-reversion': t('learn.tag_mean_reversion'),
  'crossover': t('learn.tag_crossover'), 'moving-average': t('learn.tag_moving_average'),
  'trend-following': t('learn.tag_trend_following'), 'divergence': t('learn.tag_divergence'),
  'volume': t('learn.tag_volume'), 'confirmation': t('learn.tag_confirmation'), 'fakeouts': t('learn.tag_fakeouts'),
  'stochastic': t('learn.tag_stochastic'), 'trend-strength': t('learn.tag_trend_strength'),
  'risk-reward': t('learn.tag_risk_reward'), 'optimization': t('learn.tag_optimization'),
  'fees': t('learn.tag_fees'), 'exchanges': t('learn.tag_exchanges'), 'cost-optimization': t('learn.tag_cost_optimization'),
  'binance': t('learn.tag_binance'), 'referral': t('learn.tag_referral'),
  'ichimoku': t('learn.tag_ichimoku'), 'cloud': t('learn.tag_cloud'), 'trend': t('learn.tag_trend'),
  'support-resistance': t('learn.tag_support_resistance'), 'support': t('learn.tag_support'), 'resistance': t('learn.tag_resistance'),
  'fibonacci': t('learn.tag_fibonacci'), 'retracement': t('learn.tag_retracement'),
  'technical-analysis': t('learn.tag_technical_analysis'), 'price-action': t('learn.tag_price_action'),
  'candlestick': t('learn.tag_candlestick'), 'patterns': t('learn.tag_patterns'), 'doji': t('learn.tag_doji'), 'engulfing': t('learn.tag_engulfing'),
  'institutional': t('learn.tag_institutional'), 'intraday': t('learn.tag_intraday'),
  'kelly-criterion': t('learn.tag_kelly_criterion'), 'math': t('learn.tag_math'),
  'market-review': t('learn.tag_market_review'), 'btc': t('learn.tag_btc'), 'crash': t('learn.tag_crash'),
  'real-data': t('learn.tag_real_data'), 'crypto': t('learn.tag_crypto'), 'algorithmic-trading': t('learn.tag_algorithmic_trading'),
  'python': t('learn.tag_python'), 'pruviq': t('learn.tag_pruviq'), 'origin': t('learn.tag_origin'), 'philosophy': t('learn.tag_philosophy'),
  'bb-squeeze': t('learn.tag_bb_squeeze'), 'tp': t('learn.tag_tp'), 'decision': t('learn.tag_decision'),
  'v1.7.0': t('learn.tag_v170'), 'expert-panel': t('learn.tag_expert_panel'),
  'levels': t('learn.tag_levels'), 'feb-2026': t('learn.tag_feb_2026'),
};

const levelColorMap: Record<string, string> = {
  green: 'bg-green-500/10 text-green-400 border-green-500/20',
  yellow: 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20',
  red: 'bg-red-500/10 text-red-400 border-red-500/20',
};

const levelConfig = [
  { level: 'beginner', label: t('learn.level_beginner'), title: t('learn.level_beginner_title'), desc: t('learn.level_beginner_desc'), color: 'green', posts: beginner },
  { level: 'intermediate', label: t('learn.level_intermediate'), title: t('learn.level_intermediate_title'), desc: t('learn.level_intermediate_desc'), color: 'yellow', posts: intermediate },
  { level: 'advanced', label: t('learn.level_advanced'), title: t('learn.level_advanced_title'), desc: t('learn.level_advanced_desc'), color: 'red', posts: advanced },
];
---

<Layout title={t('meta.learn_title')} description={t('meta.learn_desc')}>

  <!-- HERO -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('learn.tag')}</p>
      <h1 class="text-3xl md:text-5xl font-bold mb-4">
        {t('learn.title')}<br/>{t('learn.title2')}
      </h1>
      <p class="text-[--color-text-muted] text-lg mb-4 max-w-2xl">
        {t('learn.desc').replace('{count}', String(allPosts.length))}
      </p>
      <LearnProgress client:visible postIds={allPosts.map(p => p.id)} lang="ko" />
    </div>
  </section>

  <!-- LEVELS -->
  {levelConfig.map(({ level, label, title, desc, color, posts: levelPosts }) => (
    <section class="pb-12 border-t border-[--color-border] pt-12">
      <div class="max-w-5xl mx-auto px-4">
        <div class="flex items-center gap-3 mb-2">
          <span class={`text-xs font-mono px-2 py-0.5 rounded border ${levelColorMap[color]}`}>
            {label}
          </span>
          <h2 class="text-2xl font-bold">{title}</h2>
        </div>
        <p class="text-[--color-text-muted] text-sm mb-6">{desc}</p>

        <div class="grid md:grid-cols-2 gap-4">
          {levelPosts.map(post => (
            <LearnCard
              client:visible
              postId={post.id}
              href={post.isKorean ? `/ko/blog/${post.id}` : `/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              tags={post.data.tags}
              tagMap={tagMap}
              isEnglish={!post.isKorean}
            />
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="pb-16 border-t border-[--color-border] pt-12">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h2 class="text-xl font-bold mb-3">{t('learn.cta_title')}</h2>
      <p class="text-[--color-text-muted] text-sm mb-6">{t('learn.cta_desc')}</p>
      <a href="/ko/simulate" class="btn-primary inline-block bg-[--color-accent] text-[--color-bg] px-6 py-2.5 rounded font-semibold text-sm hover:bg-[--color-accent-dim]">
        {t('learn.cta_button')} &rarr;
      </a>
      <div class="flex flex-wrap gap-3 justify-center mt-4">
        <a href="/ko/demo" class="inline-block border border-[--color-border] px-5 py-2 rounded font-semibold text-sm hover:border-[--color-accent] transition-colors no-underline">
          {t('cross.demo_cta')} &rarr;
        </a>
        <a href="/ko/strategies" class="inline-block border border-[--color-border] px-5 py-2 rounded font-semibold text-sm hover:border-[--color-accent] transition-colors no-underline">
          {t('cross.strategies_cta')} &rarr;
        </a>
      </div>
    </div>
  </section>

</Layout>
