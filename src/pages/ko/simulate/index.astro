---
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/index';

const t = useTranslations('ko');
---

<Layout title={t('meta.builder_title')} description={t('meta.builder_desc')}>

  <!-- HERO -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('simulate.tag')}</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">
        {t('simulate.title1')}<br/>{t('simulate.title2')}
      </h1>
      <p class="text-[--color-text-muted] text-lg mb-6 max-w-2xl">
        {t('simulate.desc')}
      </p>
      <p class="text-[--color-text-muted] text-xs">
        {t('simulate.note')}
      </p>
    </div>
  </section>

  <!-- STRATEGY BUILDER -->
  <section class="pb-12 border-t border-[--color-border] pt-8">
    <div class="max-w-5xl mx-auto px-4">
      <div id="builder-mount">
        <div class="border border-[--color-border] rounded-xl p-8 bg-[--color-bg-card] text-center">
          <div class="spinner mx-auto mb-4"></div>
          <p class="text-[--color-text-muted] text-sm">{t('simulate.loading')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTED STRATEGIES -->
  <section class="pb-12 border-t border-[--color-border] pt-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-2">{t('simulate.strategies_title')}</h2>
      <p class="text-[--color-text-muted] text-sm mb-6">
        {t('simulate.strategies_desc')}
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/ko/strategies/bb-squeeze-short" class="border border-[--color-border] rounded-lg p-5 bg-[--color-bg-card] card-hover block">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-green-500/10 text-green-400 border border-green-500/20">{t('strategy.verified')}</span>
          </div>
          <h3 class="font-bold mb-1">BB Squeeze SHORT</h3>
          <p class="text-[--color-text-muted] text-xs mb-3">{t('simulate.strategy_desc_bb_short')}</p>
          <div class="grid grid-cols-2 gap-2 text-xs">
            <div><span class="text-[--color-text-muted]">{t('strategy.win_rate')}</span> <span class="font-mono font-bold text-[--color-accent] ml-1">68.6%</span></div>
            <div><span class="text-[--color-text-muted]">{t('strategy.profit_factor')}</span> <span class="font-mono font-bold text-[--color-accent] ml-1">2.22</span></div>
            <div><span class="text-[--color-text-muted]">{t('compare.trades')}</span> <span class="font-mono ml-1">2,898</span></div>
            <div><span class="text-[--color-text-muted]">{t('strategy.total_pnl')}</span> <span class="font-mono font-bold text-green-400 ml-1">+$794</span></div>
          </div>
        </a>

        <a href="/ko/strategies/bb-squeeze-long" class="border border-[--color-border] rounded-lg p-5 bg-[--color-bg-card] card-hover block">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-red-500/10 text-red-400 border border-red-500/20">{t('strategy.killed')}</span>
          </div>
          <h3 class="font-bold mb-1">BB Squeeze LONG</h3>
          <p class="text-[--color-text-muted] text-xs mb-3">{t('simulate.strategy_desc_bb_long')}</p>
          <div class="grid grid-cols-2 gap-2 text-xs">
            <div><span class="text-[--color-text-muted]">{t('strategy.win_rate')}</span> <span class="font-mono ml-1">51%</span></div>
            <div><span class="text-[--color-text-muted]">{t('strategy.profit_factor')}</span> <span class="font-mono ml-1">0.98</span></div>
            <div><span class="text-[--color-text-muted]">{t('compare.trades')}</span> <span class="font-mono ml-1">3,201</span></div>
            <div><span class="text-[--color-text-muted]">{t('strategy.total_pnl')}</span> <span class="font-mono text-red-400 ml-1">-$26</span></div>
          </div>
        </a>

        <a href="/ko/strategies/momentum-long" class="border border-[--color-border] rounded-lg p-5 bg-[--color-bg-card] card-hover block">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-red-500/10 text-red-400 border border-red-500/20">{t('strategy.killed')}</span>
          </div>
          <h3 class="font-bold mb-1">Momentum Breakout LONG</h3>
          <p class="text-[--color-text-muted] text-xs mb-3">{t('simulate.strategy_desc_momentum')}</p>
          <div class="grid grid-cols-2 gap-2 text-xs">
            <div><span class="text-[--color-text-muted]">{t('strategy.win_rate')}</span> <span class="font-mono ml-1">37.5%</span></div>
            <div><span class="text-[--color-text-muted]">{t('strategy.profit_factor')}</span> <span class="font-mono ml-1">0.42</span></div>
            <div><span class="text-[--color-text-muted]">{t('compare.trades')}</span> <span class="font-mono ml-1">1,842</span></div>
            <div><span class="text-[--color-text-muted]">{t('strategy.total_pnl')}</span> <span class="font-mono text-red-400 ml-1">-$14,115</span></div>
          </div>
        </a>
      </div>

      <div class="mt-4 text-center">
        <a href="/ko/strategies" class="text-sm text-[--color-text-muted] hover:text-[--color-accent] transition-colors">
          {t('simulate.view_all')} &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- DISCLAIMER -->
  <section class="pb-16 bg-[--color-bg-subtle]">
    <div class="max-w-5xl mx-auto px-4 text-center pt-12">
      <p class="text-[--color-text-muted] text-xs max-w-lg mx-auto">
        {t('simulate.disclaimer')}
      </p>
    </div>
  </section>

</Layout>

<script>
  import { h, render } from 'preact';
  import StrategyBuilder from '../../../components/StrategyBuilder';
  import ErrorBoundary from '../../../components/ErrorBoundary';

  const mount = document.getElementById('builder-mount');
  if (mount) {
    render(h(ErrorBoundary, { name: 'Strategy Builder' }, h(StrategyBuilder, { lang: 'ko' })), mount);
  }
</script>
