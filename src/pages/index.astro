            <p class="text-xl font-bold text-[--color-red]">7%</p>
          </div>
          <div>
            <span class="text-[--color-text-muted]">Max Drawdown</span>
            <p class="text-xl font-bold text-[--color-red]">20%</p>
          </div>
        </div>
        <p class="text-[--color-text-muted] text-xs mt-4">
          Strategy details and parameters evolve based on live performance data.
          Current configuration may differ from what's shown above.
        </p>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="system" class="py-20 border-t border-[--color-border]">
    <div class="max-w-6xl mx-auto px-4">
