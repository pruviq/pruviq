---
import '../styles/global.css'
import { getLangFromUrl, useTranslations, getAlternatePath, getBasePath } from '../i18n/index';

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  date?: string;
  category?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const altPath = getAlternatePath(Astro.url.pathname, lang);
const basePath = getBasePath(Astro.url.pathname);

const { title, description = t('meta.home_desc'), type = 'website', date, category } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://pruviq.com');
const enURL = new URL(basePath, Astro.site || 'https://pruviq.com');
const koURL = new URL(`/ko${basePath === '/' ? '' : basePath}`, Astro.site || 'https://pruviq.com');

const strategiesPath = lang === 'ko' ? '/ko/strategies' : '/strategies';
const blogPath = lang === 'ko' ? '/ko/blog' : '/blog';
const feesPath = lang === 'ko' ? '/ko/fees' : '/fees';
const changelogPath = lang === 'ko' ? '/ko/changelog' : '/changelog';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" hreflang="en" href={enURL.href} />
    <link rel="alternate" hreflang="ko" href={koURL.href} />
    <link rel="alternate" hreflang="x-default" href={enURL.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="PRUVIQ" />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <!-- JSON-LD Organization -->
    {type === 'website' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "PRUVIQ",
        "url": "https://pruviq.com",
        "description": "Free crypto strategy simulation platform. Test strategies on 500+ coins before risking real money.",
        "founder": { "@type": "Person", "name": "JPLee" },
        "sameAs": ["https://t.me/PRUVIQ"]
      })} />
    )}
    <!-- JSON-LD Article (for blog posts) -->
    {type === 'article' && date && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "datePublished": date,
        "dateModified": date,
        "author": { "@type": "Person", "name": "JPLee" },
        "publisher": {
          "@type": "Organization",
          "name": "PRUVIQ",
          "url": "https://pruviq.com"
        },
        "mainEntityOfPage": canonicalURL.href,
        "articleSection": category || "education"
      })} />
    )}
  </head>
  <body class="min-h-screen">
    <nav class="fixed top-0 w-full z-50 border-b border-[--color-border] bg-[--color-bg]/80 backdrop-blur-md">
      <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href={lang === 'ko' ? '/ko/' : '/'} class="flex items-center gap-2">
          <span class="text-[--color-accent] font-mono font-bold text-xl">PRUVIQ</span>
        </a>
        <div class="hidden md:flex items-center gap-8 text-sm">
          <a href={strategiesPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('nav.simulate')}</a>
          <a href={blogPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('nav.learn')}</a>
          <a href={feesPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('nav.fees')}</a>
          <a href={altPath} class="font-mono text-xs px-2 py-1 border border-[--color-border] rounded hover:border-[--color-accent] hover:text-[--color-accent] text-[--color-text-muted] transition-colors">{t('nav.lang')}</a>
        </div>
        <button id="mobile-menu-btn" class="md:hidden text-[--color-text-muted]">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden md:hidden border-t border-[--color-border] bg-[--color-bg]">
        <div class="flex flex-col px-4 py-4 gap-4 text-sm">
          <a href={strategiesPath} class="text-[--color-text-muted]">{t('nav.simulate')}</a>
          <a href={blogPath} class="text-[--color-text-muted]">{t('nav.learn')}</a>
          <a href={feesPath} class="text-[--color-text-muted]">{t('nav.fees')}</a>
          <a href={altPath} class="font-mono text-xs px-2 py-1 border border-[--color-border] rounded text-[--color-text-muted] w-fit">{t('nav.lang')}</a>
        </div>
      </div>
    </nav>

    <main class="pt-16">
      <slot />
    </main>

    <footer class="border-t border-[--color-border] mt-20">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="flex flex-col gap-6">
          <div class="flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="text-[--color-text-muted] text-sm">
              <span class="text-[--color-accent] font-mono font-bold">PRUVIQ</span> &mdash; {t('footer.tagline')}
            </div>
            <div class="flex items-center gap-6 text-xs text-[--color-text-muted]">
              <a href={strategiesPath} class="hover:text-[--color-text] transition-colors">{t('footer.strategies')}</a>
              <a href={blogPath} class="hover:text-[--color-text] transition-colors">{t('footer.learn')}</a>
              <a href={feesPath} class="hover:text-[--color-text] transition-colors">{t('footer.fees')}</a>
              <a href={changelogPath} class="hover:text-[--color-text] transition-colors">{t('footer.changelog')}</a>
              <a href="https://t.me/PRUVIQ" target="_blank" rel="noopener" class="hover:text-[--color-text] transition-colors">{t('footer.telegram')}</a>
            </div>
          </div>
          <div class="flex flex-col md:flex-row justify-between items-center gap-2 text-xs text-[--color-text-muted]">
            <p>{t('footer.disclaimer')}</p>
            <p>{t('footer.affiliate')} <a href={feesPath} class="text-[--color-accent] hover:underline">{t('footer.details')}</a></p>
          </div>
        </div>
      </div>
    </footer>

    <script>
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
