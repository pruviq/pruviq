---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found | PRUVIQ" description="Page not found. Explore PRUVIQ's free crypto strategy backtesting tools.">
  <section class="min-h-[60vh] flex flex-col items-center justify-center px-4 text-center">
    <p class="font-mono text-[--color-accent] text-sm tracking-widest mb-4">404</p>
    <h1 class="text-4xl font-bold mb-4">Page Not Found</h1>
    <p class="text-[--color-text-muted] mb-8 max-w-md">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="flex flex-wrap gap-4 justify-center mb-8">
      <a href="/" class="btn-primary bg-[--color-accent] text-[--color-bg] px-6 py-2 rounded font-semibold text-sm hover:bg-[--color-accent-dim]">
        Home
      </a>
      <a href="/simulate" class="border border-[--color-border] px-6 py-2 rounded text-sm hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
        Strategy Simulator
      </a>
      <a href="/strategies" class="border border-[--color-border] px-6 py-2 rounded text-sm hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
        Strategies
      </a>
    </div>
    <div class="text-sm text-[--color-text-muted]">
      <p class="mb-2">Popular pages:</p>
      <div class="flex flex-wrap gap-2 justify-center">
        <a href="/strategies/bb-squeeze-short" class="text-[--color-accent] hover:underline">BB Squeeze SHORT</a>
        <span>&middot;</span>
        <a href="/learn" class="text-[--color-accent] hover:underline">Learn</a>
        <span>&middot;</span>
        <a href="/fees" class="text-[--color-accent] hover:underline">Fees</a>
        <span>&middot;</span>
        <a href="/market" class="text-[--color-accent] hover:underline">Market</a>
      </div>
    </div>
  </section>
</Layout>
