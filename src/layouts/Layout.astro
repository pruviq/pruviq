---
import '../styles/global.css'
import { getLangFromUrl, useTranslations, getAlternatePath, getBasePath } from '../i18n/index';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  date?: string;
  category?: string;
  ogImage?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const altPath = getAlternatePath(Astro.url.pathname, lang);
const basePath = getBasePath(Astro.url.pathname);
const cfToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;

const { title, description = t('meta.home_desc'), type = 'website', date, category } = Astro.props;
const ogImage = new URL(Astro.props.ogImage || '/og-image.png', Astro.site || 'https://pruviq.com').href;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://pruviq.com');
const enURL = new URL(basePath, Astro.site || 'https://pruviq.com');
const koURL = new URL(`/ko${basePath === '/' ? '/' : basePath}`, Astro.site || 'https://pruviq.com');

const marketPath = lang === 'ko' ? '/ko/market' : '/market';
const simulatePath = lang === 'ko' ? '/ko/simulate' : '/simulate';
const learnPath = lang === 'ko' ? '/ko/learn' : '/learn';
const feesPath = lang === 'ko' ? '/ko/fees' : '/fees';
const aboutPath = lang === 'ko' ? '/ko/about' : '/about';
const changelogPath = lang === 'ko' ? '/ko/changelog' : '/changelog';
const privacyPath = lang === 'ko' ? '/ko/privacy' : '/privacy';
const termsPath = lang === 'ko' ? '/ko/terms' : '/terms';

// Legacy paths (for footer/redirects)
const strategiesPath = lang === 'ko' ? '/ko/strategies' : '/strategies';
const coinsPath = lang === 'ko' ? '/ko/coins' : '/coins';
const builderPath = lang === 'ko' ? '/ko/builder' : '/builder';
const performancePath = lang === 'ko' ? '/ko/performance' : '/performance';
const blogPath = lang === 'ko' ? '/ko/blog' : '/blog';

// Active nav detection
const navItems = [
  { href: marketPath, match: '/market', label: t('nav.market') },
  { href: strategiesPath, match: '/strategies', label: t('nav.strategies') },
  { href: coinsPath, match: '/coins', label: t('nav.coins') },
  { href: simulatePath, match: '/simulate', label: t('nav.simulate') },
  { href: learnPath, match: '/learn', label: t('nav.learn') },
  { href: feesPath, match: '/fees', label: t('nav.fees') },
];
const isActive = (match: string) => basePath.startsWith(match);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" hreflang="en" href={enURL.href} />
    <link rel="alternate" hreflang="ko" href={koURL.href} />
    <link rel="alternate" hreflang="x-default" href={enURL.href} />
    <meta name="naver-site-verification" content="ece19c45b3e33ec86f4fc79060c3283cea1493ee" />
    <meta name="yandex-verification" content="a20aa9b1eacf8e51" />
    <meta name="keywords" content={lang === 'ko'
      ? 'ΊΒυΈο╜ΊΗι Έ░▒ΊΖΝΉΛνΊΝΖ, ΊΛ╕ΈιΙΉζ┤ΈΦσ ΉιΕΈη╡ Έ╣ΝΈΞΦ, ΈΖ╕Ή╜ΦΈΥε Έ░▒ΊΖΝΉΛνΊΕ░, ΉΧΦΊα╕ΊβΦΊΠΡ ΉιΕΈη╡ ΉΜεΈχυΈιΙΉζ┤ΊΕ░, Έυ┤ΈμΝ Έ░▒ΊΖΝΉΛνΊΝΖ ΈΠΕΆ╡υ, Έ│╝Έο░ΉιΑ Έ░┤ΈΥε ΉιΕΈη╡, RSI ΉιΕΈη╡, ΊΒυΈο╜ΊΗι ΉΕιΈυ╝ Έ░▒ΊΖΝΉΛνΊΛ╕, Ά░ΑΉΔΒΊβΦΊΠΡ ΉηΡΈΠβΈπνΈπν, ΊΑΑΊΛ╕ ΊΛ╕ΈιΙΉζ┤ΈΦσ'
      : 'crypto backtesting, trading strategy builder, no-code backtester, cryptocurrency strategy simulator, free backtesting tool, Bollinger Bands strategy, RSI strategy, crypto futures backtest'
    } />
    <meta name="application-name" content="PRUVIQ" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://api.pruviq.com" crossorigin />
    <link rel="preload" href="/fonts/inter.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/jetbrains-mono.woff2" as="font" type="font/woff2" crossorigin />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="PRUVIQ" />
    <meta property="og:locale" content={lang === 'ko' ? 'ko_KR' : 'en_US'} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    <!-- JSON-LD Organization -->
    {type === 'website' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "PRUVIQ",
        "alternateName": lang === 'ko' ? 'ΊΒυΈο╜ΊΗι ΉιΕΈη╡ Ά▓ΑΉοζ ΊΦΝΈητΊΠ╝' : 'Crypto Strategy Lab',
        "url": "https://pruviq.com",
        "description": lang === 'ko'
          ? 'Έυ┤ΈμΝ ΊΒυΈο╜ΊΗι ΉιΕΈη╡ Έ░▒ΊΖΝΉΛνΊΝΖ ΊΦΝΈητΊΠ╝. 535Ά░ε Ήζ┤ΉΔΒ Ή╜ΦΉζ╕ΉΩΡΉΕε 2ΈΖΕ Ήζ┤ΉΔΒΉζα ΉΜνΉιε ΉΜεΉηξ ΈΞ░Ήζ┤ΊΕ░Έκε ΊΛ╕ΈιΙΉζ┤ΈΦσ ΉιΕΈη╡ΉζΕ ΈπΝΈΥνΆ│ι ΊΖΝΉΛνΊΛ╕ΊΧαΉΕ╕ΉγΦ.'
          : 'Free crypto strategy backtesting platform. Build and test trading strategies on 535+ coins with 2+ years of real market data.',
        "founder": { "@type": "Organization", "name": "PRUVIQ Team" },
        "sameAs": ["https://t.me/PRUVIQ"],
        "knowsAbout": lang === 'ko'
          ? ['ΉΧΦΊα╕ΊβΦΊΠΡ ΊΛ╕ΈιΙΉζ┤ΈΦσ', 'Έ░▒ΊΖΝΉΛνΊΝΖ', 'ΉΧΝΆ│ιΈουΉοα ΊΛ╕ΈιΙΉζ┤ΈΦσ', 'ΊΑΑΊΛ╕ Ά╕ΙΉε╡']
          : ['cryptocurrency trading', 'backtesting', 'algorithmic trading', 'quantitative finance']
      })} />
    )}
    <!-- JSON-LD WebApplication (homepage only) -->
    {type === 'website' && basePath === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": lang === 'ko' ? 'PRUVIQ ΉιΕΈη╡ ΉΜεΈχυΈιΙΉζ┤ΊΕ░' : 'PRUVIQ Strategy Simulator',
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "description": lang === 'ko'
          ? '535Ά░ε Ήζ┤ΉΔΒ Ή╜ΦΉζ╕ΉΩΡΉΕε ΊΒυΈο╜ΊΗι ΊΛ╕ΈιΙΉζ┤ΈΦσ ΉιΕΈη╡ΉζΕ ΈπΝΈΥνΆ│ι ΊΖΝΉΛνΊΛ╕ΊΧαΉΕ╕ΉγΦ. ΈΖ╕Ή╜ΦΈΥε ΉιΕΈη╡ Έ╣ΝΈΞΦ, Ήζ╕ΊΕ░ΈηβΊΜ░Έ╕Ν Ή░ρΊΛ╕, ΉπΕΉηΖ/Ή▓φΉΓ░ ΈπΙΉ╗ν ΉιεΆ│╡.'
          : 'Build and test crypto trading strategies on 535+ coins. No-code strategy builder with interactive charts and entry/exit markers.',
        "featureList": lang === 'ko'
          ? ['ΈΖ╕Ή╜ΦΈΥε ΉιΕΈη╡ Έ╣ΝΈΞΦ', '535+ Ή╜ΦΉζ╕ Έ░▒ΊΖΝΉΛνΊΝΖ', '11Ά░ε Ήζ┤ΉΔΒ Ά╕░ΉΙι ΉπΑΊΣε', 'Ήζ╕ΊΕ░ΈηβΊΜ░Έ╕Ν Ή░ρΊΛ╕', 'ΉΜνΆ▒░Έηα Ά▓ΑΉοζ']
          : ['No-code strategy builder', '535+ coin backtesting', '11+ technical indicators', 'Interactive charts', 'Real trading verification']
      })} />
    )}
    <!-- JSON-LD FAQPage (homepage only) -->
    {type === 'website' && basePath === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": lang === 'ko' ? [
          {
            "@type": "Question",
            "name": "PRUVIQΈηΑ Έυ┤ΉΩΘΉζ╕Ά░ΑΉγΦ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "PRUVIQΈΛΦ Έυ┤ΈμΝ ΊΒυΈο╜ΊΗι ΉιΕΈη╡ Έ░▒ΊΖΝΉΛνΊΝΖ ΊΦΝΈητΊΠ╝ΉηΖΈΜΙΈΜν. 11Ά░ε Ήζ┤ΉΔΒΉζα Ά╕░ΉΙι ΉπΑΊΣεΈξ╝ ΉΓυΉγσΊΧαΉΩυ ΈπηΉ╢ν ΊΛ╕ΈιΙΉζ┤ΈΦσ ΉιΕΈη╡ΉζΕ ΈπΝΈΥνΆ│ι, 535Ά░ε Ήζ┤ΉΔΒΉζα Ή╜ΦΉζ╕ΉΩΡΉΕε 2ΈΖΕ Ήζ┤ΉΔΒΉζα ΉΜνΉιε ΉΜεΉηξ ΈΞ░Ήζ┤ΊΕ░Έκε Έ░▒ΊΖΝΉΛνΊΛ╕ΊΧαΈσ░, ΉΙαΉΙαΈμΝΉβΑ ΉΛυΈουΊΦ╝ΉπΑΈξ╝ ΊΠυΊΧρΊΧε ΊαΕΉΜνΉιΒΉζ╕ Ά▓░Ά│╝Έξ╝ ΊβΧΉζ╕ΊΧι ΉΙα ΉηΙΉΛ╡ΈΜΙΈΜν. Ή╜ΦΈΦσ Έ╢ΙΊΧΕΉγΦ."
            }
          },
          {
            "@type": "Question",
            "name": "PRUVIQ ΉιΕΈη╡ Έ╣ΝΈΞΦΈΛΦ ΉΨ┤ΈΨ╗Ά▓Ν ΉηΣΈΠβΊΧαΈΓαΉγΦ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "ΈΖ╕Ή╜ΦΈΥε ΉιΕΈη╡ Έ╣ΝΈΞΦΉΩΡΉΕε ΉπΑΊΣε(Έ│╝Έο░ΉιΑ Έ░┤ΈΥε, RSI, MACD, EMA, ΉΛνΊΗιΉ║ΡΉΛνΊΜ▒, ADX, ATR, Ά▒░ΈηαΈθΚ ΈΥ▒)Έξ╝ AND/OR ΈΖ╝ΈουΉβΑ Έ╣ΕΆ╡Ρ ΉΩ░ΉΓ░ΉηΡΈκε Ήκ░ΊΧσΊΧι ΉΙα ΉηΙΉΛ╡ΈΜΙΈΜν. ΉπΕΉηΖ Ήκ░Ά▒┤, ΉΗΡΉιΙ, Ήζ╡ΉιΙ, ΉΜεΆ░Ε ΊΧΕΊΕ░Έξ╝ ΉΕνΉιΧΊΧε ΊδΕ 3Ή┤Ι Ήζ┤ΈΓ┤ΉΩΡ ΉιΕΉ▓┤ Ή╜ΦΉζ╕ Έ░▒ΊΖΝΉΛνΊΛ╕Έξ╝ ΉΜνΊΨΚΊΧσΈΜΙΈΜν."
            }
          },
          {
            "@type": "Question",
            "name": "PRUVIQΈΛΦ Έυ┤ΈμΝΉζ╕Ά░ΑΉγΦ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "ΈΕν, PRUVIQΉζα ΊΧ╡ΉΜυ Έ░▒ΊΖΝΉΛνΊΝΖ Ά╕░ΈΛξΉζΑ ΉβΕΉιΕ Έυ┤ΈμΝΉηΖΈΜΙΈΜν. ΉιΕΈη╡ ΈπΝΈΥνΆ╕░, 535Ά░ε Ήζ┤ΉΔΒ Ή╜ΦΉζ╕ Έ░▒ΊΖΝΉΛνΊΛ╕, ΈςρΈΥι Ά╡ΡΉεκ Ή╜αΊΖΡΉ╕ι Ήζ┤ΉγσΉζ┤ Ά▓░ΉιεΈΓα Ά│ΕΉιΧ ΉΔζΉΕ▒ ΉΩΗΉζ┤ Ά░ΑΈΛξΊΧσΈΜΙΈΜν."
            }
          },
          {
            "@type": "Question",
            "name": "PRUVIQΆ░Α ΊΛ╕ΈιΙΉζ┤ΈΦσΈ╖░ΈΓα ΈΜνΈξ╕ Έ░▒ΊΖΝΉΛνΊΝΖ ΈΠΕΆ╡υΉβΑ ΈΜνΈξ╕ ΉιΡΉζΑ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "PRUVIQΈΛΦ Ή╜ΦΈΦσ ΉΩΗΉζ┤ ΊΒυΈο╜ΊΗι ΉΕιΈυ╝ ΉιΕΉγσΉε╝Έκε ΉΕνΆ│ΕΈΡαΉΩΙΉΛ╡ΈΜΙΈΜν. TradingView(Pine Script ΊΧΕΉγΦ)ΈΓα QuantConnect(Python/C# ΊΧΕΉγΦ)ΉβΑ ΈΜυΈου Έ╣ΕΉμ╝ΉΨ╝ ΉιΕΈη╡ Έ╣ΝΈΞΦΈξ╝ ΉιεΆ│╡ΊΧσΈΜΙΈΜν. ΈαΡΊΧε ΉΜνΊΝρΈξ╝ ΊΠυΊΧρΊΧε ΉΜνΆ▒░Έηα Ά▓░Ά│╝Έξ╝ Ά│╡Ά░εΊΧαΆ│ι, 535Ά░ε Ήζ┤ΉΔΒ Ή╜ΦΉζ╕ΉζΕ ΈΠβΉΜε ΊΖΝΉΛνΊΛ╕ΊΧαΈσ░, ΈςρΈΥι ΉΜεΈχυΈιΙΉζ┤ΉΖαΉΩΡ ΊαΕΉΜνΉιΒΉζ╕ ΉΙαΉΙαΈμΝΉβΑ ΉΛυΈουΊΦ╝ΉπΑΈξ╝ ΊΠυΊΧρΊΧσΈΜΙΈΜν."
            }
          },
          {
            "@type": "Question",
            "name": "PRUVIQΉΩΡ ΉΜνΆ▒░Έηα Ά▓ΑΉοζΉζ┤ ΉηΙΈΓαΉγΦ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "ΈΕν. BB Squeeze SHORT ΉιΕΈη╡Ήζ┤ $3,000 ΉηΡΈ│╕Ήζα ΉΜνΉιε Έ░ΦΉζ┤ΈΓ╕ΉΛν ΉΕιΈυ╝ Ά│ΕΉλΝΉΩΡΉΕε Ήγ┤ΉαΒΈΡαΆ│ι ΉηΙΉΛ╡ΈΜΙΈΜν. ΉΗΡΉΜνΉζΕ ΊΠυΊΧρΊΧε ΈςρΈΥι Ά▒░ΈηαΆ░Α Ά│╡Ά░εΈΡσΈΜΙΈΜν. ΉΜνΆ▒░Έηα ΉΕ▒Ά│╝ ΊΟαΉζ┤ΉπΑΉΩΡΉΕε 38Ήζ╝ Ήζ┤ΉΔΒΉζα Ά▓ΑΉοζΈΡε ΊΛ╕ΈιΙΉζ┤ΈΦσ ΈΞ░Ήζ┤ΊΕ░ΉβΑ ΉιΕΉ▓┤ Έ▓ΕΉιΕ ΊηΙΉΛνΊΗιΈουΈξ╝ ΊβΧΉζ╕ΊΧι ΉΙα ΉηΙΉΛ╡ΈΜΙΈΜν."
            }
          }
        ] : [
          {
            "@type": "Question",
            "name": "What is PRUVIQ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "PRUVIQ is a free crypto strategy backtesting platform. You can build custom trading strategies using 11+ technical indicators, backtest them on 535+ coins with 2+ years of real market data, and see realistic results including fees and slippage. No coding required."
            }
          },
          {
            "@type": "Question",
            "name": "How does PRUVIQ's strategy builder work?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The no-code strategy builder lets you combine indicators (Bollinger Bands, RSI, MACD, EMA, Stochastic, ADX, ATR, Volume, etc.) with AND/OR logic and comparison operators. You set entry conditions, stop-loss, take-profit, and time filters, then run a full backtest across all coins in under 3 seconds."
            }
          },
          {
            "@type": "Question",
            "name": "Is PRUVIQ free?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, PRUVIQ's core backtesting features are completely free. You can build strategies, run backtests on 535+ coins, and access all education content without any payment or account creation."
            }
          },
          {
            "@type": "Question",
            "name": "What makes PRUVIQ different from TradingView or other backtesting tools?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "PRUVIQ is specifically built for crypto futures with no coding required. Unlike TradingView (requires Pine Script) or QuantConnect (requires Python/C#), PRUVIQ offers a visual strategy builder. It also publishes real trading results including failures, tests on 535+ coins simultaneously, and includes realistic fees and slippage in all simulations."
            }
          },
          {
            "@type": "Question",
            "name": "Does PRUVIQ have real trading verification?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. One strategy (BB Squeeze SHORT) runs on a real Binance Futures account with $3,000 capital. Every trade is published publicly, including losses. The live performance page shows 38+ days of verified trading data with full version history."
            }
          }
        ]
      })} />
    )}
    <!-- JSON-LD Article (for blog posts) -->
    {type === 'article' && date && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "datePublished": date,
        "dateModified": date,
        "author": { "@type": "Organization", "name": "PRUVIQ" },
        "publisher": {
          "@type": "Organization",
          "name": "PRUVIQ",
          "url": "https://pruviq.com"
        },
        "mainEntityOfPage": canonicalURL.href,
        "articleSection": category || "education"
      })} />
    )}
  </head>
  <body class="min-h-screen">
    <div id="page-loader"></div>
    <nav class="fixed top-0 w-full z-50 border-b border-[--color-border] bg-[--color-bg]/80 backdrop-blur-md" role="navigation" aria-label="Main">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href={lang === 'ko' ? '/ko/' : '/'} class="flex items-center gap-2">
          <span class="text-[--color-accent] font-mono font-bold text-xl">PRUVIQ</span>
        </a>
        <div class="hidden md:flex items-center gap-6 text-[0.8125rem]">
          {navItems.map(item => (
            <a href={item.href} class:list={[
              'transition-colors',
              isActive(item.match) ? 'text-[--color-accent] font-medium' : 'text-[--color-text-muted] hover:text-[--color-text]'
            ]}>{item.label}</a>
          ))}
          <a href={altPath} class="font-mono text-xs px-3 py-1.5 border border-[--color-border] rounded hover:border-[--color-accent] hover:text-[--color-accent] text-[--color-text-muted] transition-colors">{t('nav.lang')}</a>
        </div>
        <button id="mobile-menu-btn" class="md:hidden text-[--color-text-muted]" aria-label="Toggle menu" aria-expanded="false">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden md:hidden border-t border-[--color-border] bg-[--color-bg]">
        <div class="flex flex-col px-4 py-4 gap-1 text-sm">
          {navItems.map(item => (
            <a href={item.href} class:list={[
              'min-h-[44px] flex items-center',
              isActive(item.match) ? 'text-[--color-accent] font-medium' : 'text-[--color-text-muted]'
            ]}>{item.label}</a>
          ))}
          <a href={altPath} class="font-mono text-xs px-2 py-1 border border-[--color-border] rounded text-[--color-text-muted] w-fit min-h-[44px] flex items-center">{t('nav.lang')}</a>
        </div>
      </div>
    </nav>

    <main class="pt-16">
      <Breadcrumbs />
      <slot />
    </main>

    <footer class="border-t border-[--color-border] mt-20">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <!-- Brand + 3-column links -->
        <div class="flex flex-col md:flex-row gap-10 mb-10">
          <div class="md:w-1/3">
            <span class="text-[--color-accent] font-mono font-bold text-lg">PRUVIQ</span>
            <p class="text-[--color-text-muted] text-sm mt-2">{t('footer.tagline')}</p>
          </div>
