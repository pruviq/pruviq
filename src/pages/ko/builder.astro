---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/index';

const t = useTranslations('ko');
---

<Layout title="전략 빌더 - PRUVIQ" description="코드 없이 나만의 트레이딩 전략을 설계하세요. 지표 선택, 조건 설정, 535+ 코인 2년+ 실제 데이터로 백테스트.">
  <section class="py-12">
    <div class="max-w-5xl mx-auto px-4">
      <a href="/ko/strategies" class="text-[--color-text-muted] text-sm hover:text-[--color-accent] transition-colors mb-8 inline-block">
        &larr; 전략 라이브러리
      </a>

      <div id="builder-mount">
        <div class="border border-[--color-border] rounded-xl p-8 bg-[--color-bg-card] text-center">
          <div class="animate-pulse">
            <div class="h-3 w-32 bg-[--color-border] rounded mx-auto mb-3" />
            <div class="h-8 w-64 bg-[--color-border] rounded mx-auto mb-3" />
            <div class="h-4 w-96 max-w-full bg-[--color-border] rounded mx-auto" />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { h, render } from 'preact';
  import StrategyBuilder from '../../components/StrategyBuilder';

  const mount = document.getElementById('builder-mount');
  if (mount) {
    render(h(StrategyBuilder, { lang: 'ko' }), mount);
  }
</script>
