    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">SAVE ON FEES</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Stop Paying Full Price to Trade.</h2>
