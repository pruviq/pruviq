---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  date?: string;
  category?: string;
}

const { title, description = "Don't believe. Verify. Free crypto strategy simulation on 500+ coins. Test before you trade.", type = 'website', date, category } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://pruviq.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="PRUVIQ" />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <!-- JSON-LD Organization -->
    {type === 'website' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "PRUVIQ",
        "url": "https://pruviq.com",
        "description": "Free crypto strategy simulation platform. Test strategies on 500+ coins before risking real money.",
        "founder": { "@type": "Person", "name": "JPLee" },
        "sameAs": ["https://t.me/PRUVIQ"]
      })} />
    )}
    <!-- JSON-LD Article (for blog posts) -->
    {type === 'article' && date && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "datePublished": date,
        "dateModified": date,
        "author": { "@type": "Person", "name": "JPLee" },
        "publisher": {
          "@type": "Organization",
          "name": "PRUVIQ",
          "url": "https://pruviq.com"
        },
        "mainEntityOfPage": canonicalURL.href,
        "articleSection": category || "education"
      })} />
    )}
  </head>
  <body class="min-h-screen">
    <nav class="fixed top-0 w-full z-50 border-b border-[--color-border] bg-[--color-bg]/80 backdrop-blur-md">
      <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
          <span class="text-[--color-accent] font-mono font-bold text-xl">PRUVIQ</span>
        </a>
        <div class="hidden md:flex items-center gap-8 text-sm">
          <a href="/#approach" class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">Approach</a>
          <a href="/#evidence" class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">Evidence</a>
          <a href="/#system" class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">System</a>
          <a href="/strategies" class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">Strategies</a>
          <a href="/graveyard" class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">Graveyard</a>
          <a href="/blog" class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">Trading IQ</a>
          <a href="/fees" class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">Fees</a>
          <a href="/strategies" class="bg-[--color-accent] text-[--color-bg] px-4 py-2 rounded font-medium hover:bg-[--color-accent-dim] transition-colors">Explore Strategies</a>
        </div>
        <button id="mobile-menu-btn" class="md:hidden text-[--color-text-muted]">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden md:hidden border-t border-[--color-border] bg-[--color-bg]">
        <div class="flex flex-col px-4 py-4 gap-4 text-sm">
          <a href="/#approach" class="text-[--color-text-muted]">Approach</a>
          <a href="/#evidence" class="text-[--color-text-muted]">Evidence</a>
          <a href="/#system" class="text-[--color-text-muted]">System</a>
          <a href="/strategies" class="text-[--color-text-muted]">Strategies</a>
          <a href="/graveyard" class="text-[--color-text-muted]">Graveyard</a>
          <a href="/blog" class="text-[--color-text-muted]">Trading IQ</a>
          <a href="/fees" class="text-[--color-text-muted]">Fees</a>
          <a href="/strategies" class="bg-[--color-accent] text-[--color-bg] px-4 py-2 rounded font-medium text-center">Explore Strategies</a>
        </div>
      </div>
    </nav>

    <main class="pt-16">
      <slot />
    </main>

    <footer class="border-t border-[--color-border] mt-20">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="flex flex-col gap-6">
          <div class="flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="text-[--color-text-muted] text-sm">
              <span class="text-[--color-accent] font-mono font-bold">PRUVIQ</span> &mdash; Don't believe. Verify.
            </div>
            <div class="flex items-center gap-6 text-xs text-[--color-text-muted]">
              <a href="/strategies" class="hover:text-[--color-text] transition-colors">Strategies</a>
              <a href="/graveyard" class="hover:text-[--color-text] transition-colors">Graveyard</a>
              <a href="/blog" class="hover:text-[--color-text] transition-colors">Trading IQ</a>
              <a href="/fees" class="hover:text-[--color-text] transition-colors">Save on Fees</a>
              <a href="https://t.me/PRUVIQ" target="_blank" rel="noopener" class="hover:text-[--color-text] transition-colors">Telegram</a>
            </div>
          </div>
          <div class="flex flex-col md:flex-row justify-between items-center gap-2 text-xs text-[--color-text-muted]">
            <p>Not financial advice. Past performance does not guarantee future results.</p>
            <p>This site contains affiliate links. <a href="/fees" class="text-[--color-accent] hover:underline">Details</a></p>
          </div>
        </div>
      </div>
    </footer>

    <script>
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
