---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/index';

const t = useTranslations('ko');
---

<Layout title={t('meta.home_title')}>

  <!-- HERO -->
  <section class="min-h-[90vh] flex items-center">
    <div class="max-w-6xl mx-auto px-4 py-20">
      <div class="max-w-3xl">
        <p class="font-mono text-[--color-accent] text-sm mb-4 tracking-wider">{t('hero.tag')}</p>
        <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6">
          {t('hero.title1')}<br/>
          <span class="text-[--color-accent]">{t('hero.title2')}</span>
        </h1>
        <p class="text-lg text-[--color-text-muted] mb-2 font-mono">
          {t('hero.subtitle')}
        </p>
        <p class="text-lg md:text-xl text-[--color-text-muted] mb-8 max-w-2xl">
          {t('hero.desc')}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="/ko/strategies"
             class="bg-[--color-accent] text-[--color-bg] px-8 py-3 rounded font-semibold text-center hover:bg-[--color-accent-dim] transition-colors">
            {t('hero.cta1')} &rarr;
          </a>
          <a href="/ko/blog"
             class="border border-[--color-border] text-[--color-text] px-8 py-3 rounded font-semibold text-center hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
            {t('hero.cta2')}
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4">
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card]">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">500+</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat1')}</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card]">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">{t('hero.stat2_val')}</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat2')}</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card]">
            <p class="font-mono text-2xl font-bold">100%</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat3')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE PROBLEM -->
  <section id="the-problem" class="py-20 border-t border-[--color-border]">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('problem.tag')}</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-12">{t('problem.title')}</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
          <p class="font-mono text-[--color-red] text-3xl font-bold mb-3">-$14,115</p>
          <h3 class="font-bold mb-2">{t('problem.card1_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed mb-2">{t('problem.card1_desc')}</p>
          <p class="text-[--color-text-muted] text-xs font-mono opacity-60">{t('problem.card1_source')}</p>
        </div>
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
          <p class="font-mono text-[--color-red] text-3xl font-bold mb-3">4/5</p>
          <h3 class="font-bold mb-2">{t('problem.card2_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed mb-2">{t('problem.card2_desc')}</p>
          <p class="text-[--color-text-muted] text-xs font-mono opacity-60">{t('problem.card2_source')}</p>
        </div>
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
          <p class="font-mono text-[--color-red] text-3xl font-bold mb-3">6/6</p>
          <h3 class="font-bold mb-2">{t('problem.card3_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed mb-2">{t('problem.card3_desc')}</p>
          <p class="text-[--color-text-muted] text-xs font-mono opacity-60">{t('problem.card3_source')}</p>
        </div>
      </div>

      <div class="mt-8 text-center">
        <p class="text-[--color-text-muted] text-lg">
          {t('problem.hook')}
          <strong class="text-[--color-accent]"> {t('problem.hook_accent')}</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- EVIDENCE (merged from THE ANSWER + EVIDENCE) -->
  <section id="evidence" class="py-20 border-t border-[--color-border]">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('evidence.tag')}</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{t('evidence.title')}</h2>
      <p class="text-[--color-text-muted] text-lg mb-12 max-w-2xl">{t('evidence.desc')}</p>

      <div class="grid md:grid-cols-2 gap-8 mb-8">
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="font-mono text-[--color-accent] text-lg font-bold shrink-0 w-8">01</div>
            <div>
              <h3 class="font-bold mb-1">{t('evidence.step1_title')}</h3>
              <p class="text-[--color-text-muted] text-sm">{t('evidence.step1_desc')}</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="font-mono text-[--color-accent] text-lg font-bold shrink-0 w-8">02</div>
            <div>
              <h3 class="font-bold mb-1">{t('evidence.step2_title')}</h3>
              <p class="text-[--color-text-muted] text-sm">{t('evidence.step2_desc')}</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="font-mono text-[--color-accent] text-lg font-bold shrink-0 w-8">03</div>
            <div>
              <h3 class="font-bold mb-1">{t('evidence.step3_title')}</h3>
              <p class="text-[--color-text-muted] text-sm">{t('evidence.step3_desc')}</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="font-mono text-[--color-accent] text-lg font-bold shrink-0 w-8">04</div>
            <div>
              <h3 class="font-bold mb-1">{t('evidence.step4_title')}</h3>
              <p class="text-[--color-text-muted] text-sm">{t('evidence.step4_desc')}</p>
            </div>
          </div>
        </div>

        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
          <h3 class="font-mono text-[--color-accent] text-sm mb-4">{t('evidence.lesson_tag')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed mb-4">
            {t('evidence.lesson1')} <strong class="text-[--color-red]">{t('evidence.lesson_loss')}</strong> {t('evidence.lesson1_end')}
          </p>
          <p class="text-[--color-text-muted] text-sm leading-relaxed mb-4">{t('evidence.lesson2')}</p>
          <p class="text-[--color-text-muted] text-sm leading-relaxed mb-4">{t('evidence.lesson3')}</p>
          <p class="text-[--color-accent] font-mono font-bold">{t('evidence.lesson_rule')}</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-8">
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
          <h3 class="font-mono text-[--color-accent] text-sm mb-4">{t('evidence.publish_tag')}</h3>
          <div class="space-y-3 text-sm">
            <div class="flex gap-3"><span class="text-[--color-accent] shrink-0">+</span><p>{t('evidence.publish1')}</p></div>
            <div class="flex gap-3"><span class="text-[--color-accent] shrink-0">+</span><p>{t('evidence.publish2')}</p></div>
            <div class="flex gap-3"><span class="text-[--color-accent] shrink-0">+</span><p>{t('evidence.publish3')}</p></div>
            <div class="flex gap-3"><span class="text-[--color-accent] shrink-0">+</span><p>{t('evidence.publish4')}</p></div>
            <div class="flex gap-3"><span class="text-[--color-accent] shrink-0">+</span><p>{t('evidence.publish5')}</p></div>
          </div>
        </div>
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
          <h3 class="font-mono text-[--color-red] text-sm mb-4">{t('evidence.nopromise_tag')}</h3>
          <div class="space-y-3 text-sm">
            <div class="flex gap-3"><span class="text-[--color-red] shrink-0">&times;</span><p>{t('evidence.nopromise1')}</p></div>
            <div class="flex gap-3"><span class="text-[--color-red] shrink-0">&times;</span><p>{t('evidence.nopromise2')}</p></div>
            <div class="flex gap-3"><span class="text-[--color-red] shrink-0">&times;</span><p>{t('evidence.nopromise3')}</p></div>
            <div class="flex gap-3"><span class="text-[--color-red] shrink-0">&times;</span><p>{t('evidence.nopromise4')}</p></div>
            <div class="flex gap-3"><span class="text-[--color-red] shrink-0">&times;</span><p>{t('evidence.nopromise5')}</p></div>
          </div>
        </div>
      </div>

      <!-- TRY IT YOURSELF teaser -->
      <div class="border border-[--color-accent] rounded-lg p-6 bg-[--color-bg-card] mb-8">
        <h3 class="font-mono text-[--color-accent] text-sm mb-3">{t('evidence.try_tag')}</h3>
        <p class="text-[--color-text-muted] text-sm leading-relaxed mb-4">{t('evidence.try_desc')}</p>
        <a href="/ko/strategies/bb-squeeze-short#demo"
           class="inline-block bg-[--color-accent] text-[--color-bg] px-6 py-2 rounded font-semibold text-sm hover:bg-[--color-accent-dim] transition-colors">
          {t('evidence.try_cta')} &rarr;
        </a>
      </div>

      <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
        <h3 class="font-mono text-[--color-accent] text-sm mb-4">{t('evidence.sim_tag')}</h3>
        <div class="grid sm:grid-cols-4 gap-6 font-mono text-sm">
          <div>
            <span class="text-[--color-text-muted]">{t('evidence.sim_coins')}</span>
            <p class="text-xl font-bold">500+</p>
          </div>
          <div>
            <span class="text-[--color-text-muted]">{t('evidence.sim_data')}</span>
            <p class="text-xl font-bold">{t('hero.stat2_val')}</p>
          </div>
          <div>
            <span class="text-[--color-text-muted]">{t('evidence.sim_fees')}</span>
            <p class="text-xl font-bold">{t('evidence.sim_fees_val')}</p>
          </div>
          <div>
            <span class="text-[--color-text-muted]">{t('evidence.sim_slippage')}</span>
            <p class="text-xl font-bold">{t('evidence.sim_slippage_val')}</p>
          </div>
        </div>
        <p class="text-[--color-text-muted] text-xs mt-4">{t('evidence.sim_note')}</p>
      </div>
    </div>
  </section>

  <!-- THE SYSTEM -->
  <section id="system" class="py-20 border-t border-[--color-border]">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('system.tag')}</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{t('system.title')}</h2>
      <p class="text-[--color-text-muted] text-lg mb-12 max-w-2xl">{t('system.desc')}</p>

      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] text-center">
          <p class="font-mono text-[--color-accent] text-4xl font-bold mb-2">{t('system.step1')}</p>
          <p class="text-[--color-text-muted] text-sm">{t('system.step1_desc')}</p>
        </div>
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] text-center">
          <p class="font-mono text-[--color-accent] text-4xl font-bold mb-2">{t('system.step2')}</p>
          <p class="text-[--color-text-muted] text-sm">{t('system.step2_desc')}</p>
        </div>
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] text-center">
          <p class="font-mono text-[--color-accent] text-4xl font-bold mb-2">{t('system.step3')}</p>
          <p class="text-[--color-text-muted] text-sm">{t('system.step3_desc')}</p>
        </div>
      </div>

      <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
        <h3 class="font-mono text-[--color-accent] text-sm mb-4">{t('system.engine_tag')}</h3>
        <div class="grid sm:grid-cols-3 gap-4 font-mono text-sm">
          <div class="flex justify-between border-b border-[--color-border] pb-2 sm:border-0">
            <span class="text-[--color-text-muted]">Engine</span>
            <span>Python + Pandas</span>
          </div>
          <div class="flex justify-between border-b border-[--color-border] pb-2 sm:border-0">
            <span class="text-[--color-text-muted]">Data</span>
            <span>ccxt (Multi-Exchange)</span>
          </div>
          <div class="flex justify-between border-b border-[--color-border] pb-2 sm:border-0">
            <span class="text-[--color-text-muted]">Storage</span>
            <span>Parquet</span>
          </div>
          <div class="flex justify-between border-b border-[--color-border] pb-2 sm:border-0">
            <span class="text-[--color-text-muted]">Bias Prevention</span>
            <span>5 QA Tests</span>
          </div>
          <div class="flex justify-between border-b border-[--color-border] pb-2 sm:border-0">
            <span class="text-[--color-text-muted]">Cost Model</span>
            <span>Fees + Slippage</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[--color-text-muted]">Community</span>
            <span>Telegram</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 border-t border-[--color-border]">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <p class="font-mono text-[--color-text-muted] text-sm mb-4 tracking-wider">{t('cta.tag')}</p>
      <h2 class="text-3xl md:text-5xl font-bold mb-4">
        <span class="text-[--color-accent]">{t('cta.title')}</span>
      </h2>
      <p class="text-[--color-text-muted] text-lg mb-4 max-w-xl mx-auto">{t('cta.desc1')}</p>
      <p class="text-[--color-text-muted] text-sm mb-8 max-w-md mx-auto">{t('cta.desc2')}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-4">
        <a href="/ko/strategies"
           class="inline-block bg-[--color-accent] text-[--color-bg] px-10 py-4 rounded font-semibold text-lg hover:bg-[--color-accent-dim] transition-colors">
          {t('cta.button1')} &rarr;
        </a>
        <a href="https://t.me/PRUVIQ" target="_blank" rel="noopener"
           class="inline-block border border-[--color-border] text-[--color-text] px-10 py-4 rounded font-semibold text-lg hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
          {t('cta.button2')}
        </a>
      </div>
      <p class="text-[--color-text-muted] text-xs mt-6 max-w-lg mx-auto">{t('cta.disclaimer')}</p>
    </div>
  </section>

</Layout>
