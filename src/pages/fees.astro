---
import Layout from '../layouts/Layout.astro';
import FeeCalculator from '../components/FeeCalculator';
import { useTranslations } from '../i18n/index';
import { exchanges, formatFeeRange } from '../data/exchanges';

const t = useTranslations('en');

const exchangeCards: Record<string, { tagLabel: string; description: string }> = {
  binance: {
    tagLabel: '#1 VOLUME',
    description: 'Deepest order books. Lowest slippage. PRUVIQ simulations use Binance data.',
  },
  bitget: {
    tagLabel: 'COPY TRADING',
    description: 'Leading copy trading platform. Follow successful traders automatically.',
  },
  okx: {
    tagLabel: '120+ COUNTRIES',
    description: 'Available in 120+ countries. Good alternative when Binance is restricted.',
  },
};
---

<Layout title={t('meta.fees_title')} description={t('meta.fees_desc')}>

  <!-- HERO -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('fees.tag')}</p>
      <h1 class="text-3xl md:text-5xl font-bold mb-4">
        {t('fees.title1')}<br/>{t('fees.title2')}
      </h1>
      <p class="text-[--color-text-muted] text-lg mb-4 max-w-2xl">
        {t('fees.desc')}
      </p>
      <p class="text-[--color-text-muted] text-xs">
        {t('fees.disclosure')}
      </p>
    </div>
  </section>

  <!-- INTERACTIVE FEE CALCULATOR -->
  <section class="pb-12 border-t border-[--color-border] pt-12">
    <div class="max-w-5xl mx-auto px-4">
      <FeeCalculator client:visible lang="en" />
    </div>
  </section>

  <!-- 3 EXCHANGE CARDS -->
  <section class="pb-12 border-t border-[--color-border] pt-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-2">Compare Exchanges</h2>
      <p class="text-[--color-text-muted] text-sm mb-6">Base tier (VIP 0). Referral discounts stack on top of VIP tiers.</p>

      <div class="grid md:grid-cols-3 gap-6">
        {exchanges.map((ex) => {
          const card = exchangeCards[ex.id];
          return (
            <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] flex flex-col">
              <div class="font-mono text-[--color-accent] text-xs font-bold mb-1">{card.tagLabel}</div>
              <h3 class="text-xl font-bold mb-3">{ex.name}</h3>
              <div class="space-y-2 text-sm mb-4 flex-grow">
                <div class="flex justify-between">
                  <span class="text-[--color-text-muted]">Spot</span>
                  <span class="font-mono">{formatFeeRange(ex.spot, 'spot')}</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[--color-text-muted]">Futures</span>
                  <span class="font-mono">{formatFeeRange(ex.futures, 'futures')}</span>
                </div>
                <div class="flex justify-between border-t border-[--color-border] pt-2 mt-2">
                  <span class="text-[--color-accent] font-medium">PRUVIQ Discount</span>
                  <span class="font-mono font-bold text-[--color-accent]">{ex.discountLabel} off</span>
                </div>
              </div>
              <p class="text-[--color-text-muted] text-xs mb-4">{card.description}</p>
              {ex.available ? (
                <a href={ex.referralUrl} target="_blank" rel="noopener"
                   class="block text-center bg-[--color-accent] text-[--color-bg] px-4 py-2 rounded text-sm font-semibold hover:opacity-90 transition-opacity">
                  Sign Up &rarr;
                </a>
              ) : (
                <span class="block text-center bg-[--color-border] text-[--color-text-muted] px-4 py-2 rounded text-sm font-semibold cursor-default">
                  Coming Soon
                </span>
              )}
            </div>
          );
        })}
      </div>

      <p class="text-[--color-text-muted] text-xs mt-4">
        Maker / Taker rates shown. Higher-volume traders unlock lower tiers automatically. Last updated: Feb 2026.
      </p>
    </div>
  </section>

  <!-- FAQ (compact) -->
  <section class="pb-16 border-t border-[--color-border] pt-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-6">FAQ</h2>

      <div class="space-y-4 max-w-3xl">
        <details class="border border-[--color-border] rounded-lg bg-[--color-bg-card] group">
          <summary class="p-4 cursor-pointer font-medium flex justify-between items-center">
            Does PRUVIQ earn from this?
            <span class="text-[--color-text-muted] group-open:rotate-45 transition-transform text-xl leading-none">+</span>
          </summary>
          <p class="px-4 pb-4 text-[--color-text-muted] text-sm">
            Yes. Exchanges pay PRUVIQ a commission from their revenue.
            This does NOT come from your pocket — your fees are always lower with a referral than without one.
          </p>
        </details>

        <details class="border border-[--color-border] rounded-lg bg-[--color-bg-card] group">
          <summary class="p-4 cursor-pointer font-medium flex justify-between items-center">
            What's the difference between Spot and Futures?
            <span class="text-[--color-text-muted] group-open:rotate-45 transition-transform text-xl leading-none">+</span>
          </summary>
          <p class="px-4 pb-4 text-[--color-text-muted] text-sm">
            Spot = buy/sell crypto directly. Futures = trade contracts with leverage (higher risk, lower fees per dollar traded).
          </p>
        </details>

        <details class="border border-[--color-border] rounded-lg bg-[--color-bg-card] group">
          <summary class="p-4 cursor-pointer font-medium flex justify-between items-center">
            I already have an account. Can I still get a discount?
            <span class="text-[--color-text-muted] group-open:rotate-45 transition-transform text-xl leading-none">+</span>
          </summary>
          <p class="px-4 pb-4 text-[--color-text-muted] text-sm">
            Referral discounts must be applied at account creation. Existing accounts may not qualify retroactively.
          </p>
        </details>
      </div>

      <p class="text-[--color-text-muted] text-xs mt-8 max-w-lg">
        Affiliate disclosure: PRUVIQ earns a commission from exchanges when you sign up through our referral links.
        Your fee discounts are not affected. Not financial advice. Crypto trading involves substantial risk of loss.
      </p>
    </div>
  </section>

</Layout>
