---
import Layout from '../../layouts/Layout.astro';
import MarketDashboard from '../../components/MarketDashboard';
import { useTranslations } from '../../i18n/index';
import ErrorBoundary from '../../components/ErrorBoundary';

const t = useTranslations('en');
---

<Layout title={t('meta.market_title')} description={t('meta.market_desc')}>
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('market.tag')}</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">{t('market.title')}</h1>
      <p class="text-[--color-text-muted] text-lg mb-8 max-w-2xl">
        {t('market.desc')}
      </p>
      <ErrorBoundary client:visible name="Market Dashboard"><MarketDashboard client:visible lang="en" /></ErrorBoundary>
    </div>
  </section>
</Layout>
