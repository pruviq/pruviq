          ? ['ВЋћьўИьЎћьЈљ ьіИваѕВЮ┤вћЕ', 'в░▒ьЁїВіцьїЁ', 'ВЋїЖ│авдгВдў ьіИваѕВЮ┤вћЕ', 'ьђђьіИ ЖИѕВюх']
          : ['cryptocurrency trading', 'backtesting', 'algorithmic trading', 'quantitative finance']
      })} />
    )}
    <!-- JSON-LD WebApplication (homepage only) -->
    {type === 'website' && basePath === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": lang === 'ko' ? 'PRUVIQ Ваёвъх ВІюв«гваѕВЮ┤ьё░' : 'PRUVIQ Strategy Simulator',
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "description": lang === 'ko'
          ? '549Ж░ю ВЮ┤ВЃЂ ВйћВЮИВЌљВёю ьЂгвдйьєа ьіИваѕВЮ┤вћЕ ВаёвъхВЮё вДївЊцЖ│а ьЁїВіцьіИьЋўВёИВџћ. вЁИВйћвЊю Ваёвъх в╣ївЇћ, ВЮИьё░въЎьІ░вИї В░еьіИ, ВДёВъЁ/В▓ГВѓ░ вДѕВ╗ц ВаюЖ│х.'
          : 'Build and test crypto trading strategies on 549+ coins. No-code strategy builder with interactive charts and entry/exit markers.',
        "featureList": lang === 'ko'
          ? ['вЁИВйћвЊю Ваёвъх в╣ївЇћ', '549+ ВйћВЮИ в░▒ьЁїВіцьїЁ', '11Ж░ю ВЮ┤ВЃЂ ЖИ░Вѕа ВДђьЉю', 'ВЮИьё░въЎьІ░вИї В░еьіИ', 'ВІцЖ▒░въў Ж▓ђВдЮ']
          : ['No-code strategy builder', '549+ coin backtesting', '11+ technical indicators', 'Interactive charts', 'Real trading verification']
      })} />
    )}
    <!-- JSON-LD FAQPage (homepage only) -->
    {type === 'website' && basePath === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": lang === 'ko' ? [
          {
            "@type": "Question",
            "name": "PRUVIQвъђ вг┤ВЌЄВЮИЖ░ђВџћ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "PRUVIQвіћ вг┤вБї ьЂгвдйьєа Ваёвъх в░▒ьЁїВіцьїЁ ьћївъФьЈ╝ВъЁвІѕвІц. 11Ж░ю ВЮ┤ВЃЂВЮў ЖИ░Вѕа ВДђьЉювЦ╝ ВѓгВџЕьЋўВЌг вДъВХц ьіИваѕВЮ┤вћЕ ВаёвъхВЮё вДївЊцЖ│а, 549Ж░ю ВЮ┤ВЃЂВЮў ВйћВЮИВЌљВёю 2вЁё ВЮ┤ВЃЂВЮў ВІцВаю ВІюВъЦ вЇ░ВЮ┤ьё░вАю в░▒ьЁїВіцьіИьЋўвЕ░, ВѕўВѕўвБїВЎђ Вігвдгьћ╝ВДђвЦ╝ ьЈгьЋеьЋю ьўёВІцВаЂВЮИ Ж▓░Ж│╝вЦ╝ ьЎЋВЮИьЋа Вѕў ВъѕВіхвІѕвІц. ВйћвћЕ вХѕьЋёВџћ."
            }
          },
          {
            "@type": "Question",
            "name": "PRUVIQ Ваёвъх в╣ївЇћвіћ Вќ┤вќ╗Ж▓ї ВъЉвЈЎьЋўвѓўВџћ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "вЁИВйћвЊю Ваёвъх в╣ївЇћВЌљВёю ВДђьЉю(в│╝вд░Вађ в░┤вЊю, RSI, MACD, EMA, ВіцьєаВ║љВіцьІ▒, ADX, ATR, Ж▒░въўвЪЅ вЊ▒)вЦ╝ AND/OR вЁ╝вдгВЎђ в╣ёЖхљ ВЌ░Вѓ░ВъљвАю ВА░ьЋЕьЋа Вѕў ВъѕВіхвІѕвІц. ВДёВъЁ ВА░Ж▒┤, ВєљВаѕ, ВЮхВаѕ, ВІюЖ░ё ьЋёьё░вЦ╝ ВёцВаЋьЋю ьЏё 3В┤ѕ ВЮ┤вѓ┤ВЌљ ВаёВ▓┤ ВйћВЮИ в░▒ьЁїВіцьіИвЦ╝ ВІцьќЅьЋЕвІѕвІц."
            }
          },
          {
            "@type": "Question",
            "name": "PRUVIQвіћ вг┤вБїВЮИЖ░ђВџћ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "вёц, PRUVIQВЮў ьЋхВІг в░▒ьЁїВіцьїЁ ЖИ░віЦВЮђ ВЎёВаё вг┤вБїВъЁвІѕвІц. Ваёвъх вДївЊцЖИ░, 549Ж░ю ВЮ┤ВЃЂ ВйћВЮИ в░▒ьЁїВіцьіИ, вфевЊа ЖхљВюА ВйўьЁљВИа ВЮ┤ВџЕВЮ┤ Ж▓░Ваювѓў Ж│ёВаЋ ВЃЮВё▒ ВЌєВЮ┤ Ж░ђвіЦьЋЕвІѕвІц."
            }
          },
          {
            "@type": "Question",
            "name": "PRUVIQВЌљ ВІцЖ▒░въў Ж▓ђВдЮВЮ┤ ВъѕвѓўВџћ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "вёц. BB Squeeze SHORT ВаёвъхВЮ┤ $3,000 Въљв│ИВЮў ВІцВаю в░ћВЮ┤вѓИВіц Вёавг╝ Ж│ёВбїВЌљВёю Вџ┤ВўЂвљўЖ│а ВъѕВіхвІѕвІц. ВєљВІцВЮё ьЈгьЋеьЋю вфевЊа Ж▒░въўЖ░ђ Ж│хЖ░ювљЕвІѕвІц. ВІцЖ▒░въў Вё▒Ж│╝ ьјўВЮ┤ВДђВЌљВёю 38ВЮ╝ ВЮ┤ВЃЂВЮў Ж▓ђВдЮвљю ьіИваѕВЮ┤вћЕ вЇ░ВЮ┤ьё░ВЎђ ВаёВ▓┤ в▓ёВаё ьъѕВіцьєавдгвЦ╝ ьЎЋВЮИьЋа Вѕў ВъѕВіхвІѕвІц."
            }
          }
        ] : [
          {
            "@type": "Question",
            "name": "What is PRUVIQ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "PRUVIQ is a free crypto strategy backtesting platform. You can build custom trading strategies using 11+ technical indicators, backtest them on 549+ coins with 2+ years of real market data, and see realistic results including fees and slippage. No coding required."
            }
          },
          {
            "@type": "Question",
            "name": "How does PRUVIQ's strategy builder work?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The no-code strategy builder lets you combine indicators (Bollinger Bands, RSI, MACD, EMA, Stochastic, ADX, ATR, Volume, etc.) with AND/OR logic and comparison operators. You set entry conditions, stop-loss, take-profit, and time filters, then run a full backtest across all coins in under 3 seconds."
            }
          },
          {
            "@type": "Question",
            "name": "Is PRUVIQ free?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, PRUVIQ's core backtesting features are completely free. You can build strategies, run backtests on 549+ coins, and access all education content without any payment or account creation."
            }
          },
          {
            "@type": "Question",
            "name": "What makes PRUVIQ different from TradingView or other backtesting tools?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "PRUVIQ is specifically built for crypto futures with no coding required. Unlike TradingView (requires Pine Script) or QuantConnect (requires Python/C#), PRUVIQ offers a visual strategy builder. It also publishes real trading results including failures, tests on 549+ coins simultaneously, and includes realistic fees and slippage in all simulations."
            }
          },
          {
            "@type": "Question",
            "name": "Does PRUVIQ have real trading verification?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. One strategy (BB Squeeze SHORT) runs on a real Binance Futures account with $3,000 capital. Every trade is published publicly, including losses. The live performance page shows 38+ days of verified trading data with full version history."
            }
          }
        ]
      })} />
    )}
    <!-- JSON-LD Article (for blog posts) -->
    {type === 'article' && date && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "datePublished": date,
        "dateModified": date,
        "author": { "@type": "Organization", "name": "PRUVIQ" },
        "publisher": {
          "@type": "Organization",
          "name": "PRUVIQ",
          "url": "https://pruviq.com"
        },
        "mainEntityOfPage": canonicalURL.href,
        "articleSection": category || "education"
      })} />
    )}
    <!-- JSON-LD BreadcrumbList -->
    {basePath !== '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://pruviq.com/" },
          { "@type": "ListItem", "position": 2, "name": title, "item": canonicalURL.href }
        ]
      })} />
    )}
    <!-- JSON-LD HowTo (homepage) -->
    {type === 'website' && basePath === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "HowTo",
        "name": lang === 'ko' ? 'PRUVIQвАю ьЂгвдйьєа Ваёвъх в░▒ьЁїВіцьіИьЋўвіћ в░Ев▓Ћ' : 'How to Backtest a Crypto Strategy with PRUVIQ',
        "description": lang === 'ko' ? '3вІеЖ│ёвАю ьіИваѕВЮ┤вћЕ ВаёвъхВЮё вг┤вБївАю Ж▓ђВдЮьЋўВёИВџћ' : 'Verify your trading strategy in 3 steps for free',
        "totalTime": "PT3M",
        "step": [
          { "@type": "HowToStep", "position": 1, "name": "Select", "text": "Pick a strategy from the library or build your own using the no-code builder with 11+ indicators." },
          { "@type": "HowToStep", "position": 2, "name": "Simulate", "text": "Run it on 549+ coins with 2+ years of historical data. Fees and slippage included." },
          { "@type": "HowToStep", "position": 3, "name": "Verify", "text": "Review win rate, drawdown, profit factor, and losing streaks. Then decide if it's worth trading." }
        ]
      })} />
    )}
</head>
  <body class="min-h-screen">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-[--color-accent] focus:text-white focus:rounded">
      Skip to main content
    </a>
    <div id="page-loader"></div>
    <header>
    <nav class="fixed top-0 w-full z-50 border-b border-[--color-border] bg-[--color-bg]/80 backdrop-blur-md" role="navigation" aria-label="Main">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href={lang === 'ko' ? '/ko/' : '/'} class="flex items-center gap-2">
          <span class="text-[--color-accent] font-mono font-bold text-xl">PRUVIQ</span>
        </a>
        <div class="hidden md:flex items-center gap-6 text-[0.8125rem]">
          {navItems.map(item => (
            <a href={item.href} class:list=[
              'transition-colors',
              isActive(item.match) ? 'text-[--color-accent] font-medium' : 'text-[--color-text-muted] hover:text-[--color-text]'
            ]>{item.label}</a>
          ))}
          <a href={altPath} class="font-mono text-xs px-3 py-1.5 border border-[--color-border] rounded hover:border-[--color-accent] hover:text-[--color-accent] text-[--color-text-muted] transition-colors">{t('nav.lang')}</a>
        </div>
        <button id="mobile-menu-btn" class="md:hidden text-[--color-text-muted]" aria-label="Toggle menu" aria-expanded="false">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden md:hidden border-t border-[--color-border] bg-[--color-bg]">
        <div class="flex flex-col px-4 py-4 gap-1 text-sm">
          {navItems.map(item => (
            <a href={item.href} class:list=[
              'min-h-[44px] flex items-center',
              isActive(item.match) ? 'text-[--color-accent] font-medium' : 'text-[--color-text-muted]'
            ]>{item.label}</a>
          ))}
          <a href={altPath} class="font-mono text-xs px-2 py-1 border border-[--color-border] rounded text-[--color-text-muted] w-fit min-h-[44px] flex items-center">{t('nav.lang')}</a>
        </div>
      </div>
    </nav>
    </header>

    <main id="main-content" role="main" aria-label="Page content" class="pt-16">
      <Breadcrumbs />
      <slot />
    </main>

    <footer class="border-t border-[--color-border] mt-20" role="contentinfo" aria-label="Site footer">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <!-- Brand + 3-column links -->
        <div class="flex flex-col md:flex-row gap-10 mb-10">
          <div class="md:w-1/3">
            <span class="text-[--color-accent] font-mono font-bold text-lg">PRUVIQ</span>
            <p class="text-[--color-text-muted] text-sm mt-2">{t('footer.tagline')}</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 md:w-2/3 text-sm">
            <div>
              <p class="font-mono text-[--color-text-muted] text-xs uppercase tracking-wider mb-3">{t('footer.col_product')}</p>
              <div class="flex flex-col gap-2">
                <a href={marketPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('nav.market')}</a>
                <a href={simulatePath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('nav.simulate')}</a>
                <a href={strategiesPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('nav.strategies')}</a>
                <a href={coinsPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('nav.coins')}</a>
                <a href={feesPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('footer.fees')}</a>
              </div>
            </div>
            <div>
              <p class="font-mono text-[--color-text-muted] text-xs uppercase tracking-wider mb-3">{t('footer.col_resources')}</p>
              <div class="flex flex-col gap-2">
                <a href={learnPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('nav.learn')}</a>
                <a href={blogPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('nav.blog')}</a>
                <a href={aboutPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('footer.about')}</a>
                <a href={changelogPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('footer.changelog')}</a>
                <a href={methodologyPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('footer.methodology')}</a>
                <a href={apiPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('footer.api')}</a>
                <a href={compareTvPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('footer.compare')}</a>
                <a href="https://t.me/PRUVIQ" target="_blank" rel="noopener noreferrer" class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('footer.telegram')}</a>
                <a href="https://x.com/pruviq_com" target="_blank" rel="noopener noreferrer" class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">Twitter / X</a>
                <a href="https://github.com/poong92/pruviq" target="_blank" rel="noopener noreferrer" class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">GitHub</a>
              </div>
            </div>
            <div>
              <p class="font-mono text-[--color-text-muted] text-xs uppercase tracking-wider mb-3">{t('footer.col_legal')}</p>
              <div class="flex flex-col gap-2">
                <a href={privacyPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('footer.privacy')}</a>
                <a href={termsPath} class="text-[--color-text-muted] hover:text-[--color-text] transition-colors">{t('footer.terms')}</a>
