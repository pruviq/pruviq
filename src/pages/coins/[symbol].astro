---
import Layout from '../../layouts/Layout.astro';
import { COIN_SYMBOLS } from '../../data/coin-symbols';
import { useTranslations } from '../../i18n/index';
import fs from 'node:fs';

const t = useTranslations('en');

let coinMeta: Record<string, { name: string; image: string }> = {};
try {
  const raw = fs.readFileSync('public/data/coin-metadata.json', 'utf-8');
  coinMeta = JSON.parse(raw);
} catch {}

export async function getStaticPaths() {
  return COIN_SYMBOLS.flatMap(s => {
    const slug = s.toLowerCase();
    const entries = [
      { params: { symbol: slug }, props: { symbolUpper: s } },
    ];
    if (slug.endsWith('usdt')) {
      const base = slug.slice(0, -4);
      if (base) entries.push({ params: { symbol: base }, props: { symbolUpper: s } });
    }
    return entries;
  });
}

const { symbol } = Astro.params;
const { symbolUpper } = Astro.props;
const displayName = symbolUpper.replace('USDT', '') + '/USDT';
const coinName = symbolUpper.replace('USDT', '');
const fullName = coinMeta[symbolUpper]?.name || coinName;
const metaDesc = `${fullName} (${displayName}) trading strategy simulation — backtest BB Squeeze SHORT on ${displayName} with 2+ years of data. See entry/exit signals, win rate, and profit factor. Free on PRUVIQ.`;
const datasetJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": `${fullName} Trading Strategy Backtest`,
  "description": `BB Squeeze SHORT strategy simulation results for ${displayName} with 2+ years of historical OHLCV data`,
  "temporalCoverage": "2024/2026",
  "creator": { "@type": "Organization", "name": "PRUVIQ" },
  "license": "https://creativecommons.org/licenses/by-nc/4.0/"
});
const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What is the BB Squeeze SHORT strategy for ${fullName}?`,
      "acceptedAnswer": { "@type": "Answer", "text": `The BB Squeeze SHORT strategy detects Bollinger Band compression on ${displayName} and enters a short position when a downward breakout occurs. It uses a 10% stop-loss and 8% take-profit with up to 48-hour holding periods.` }
    },
    {
      "@type": "Question",
      "name": `How reliable is the ${fullName} backtest on PRUVIQ?`,
      "acceptedAnswer": { "@type": "Answer", "text": "PRUVIQ backtests use 2+ years of 1-hour OHLCV data from Binance Futures. All results are out-of-sample tested with Monte Carlo validation (10,000 iterations). No look-ahead bias — only completed candles are used for signals." }
    },
    {
      "@type": "Question",
      "name": `Can I simulate ${fullName} strategies for free?`,
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. PRUVIQ is 100% free. You can simulate the BB Squeeze strategy on any supported coin, adjust parameters, and view detailed equity curves and trade logs — no account required." }
    }
  ]
});

// Canonical override: prefer USDT variant as canonical when this page is the base symbol
const canonicalOverride = symbol.endsWith('usdt') ? undefined : `/coins/${symbol}usdt/`;
---

<Layout title={`${fullName} (${displayName}) - ${t('meta.coins_title')}`} description={metaDesc} canonicalOverride={canonicalOverride}>
  <script type="application/ld+json" set:html={datasetJsonLd} />
  <script type="application/ld+json" set:html={faqJsonLd} />
  <section class="py-8">
    <div class="max-w-6xl mx-auto px-4">
      <a href="/coins" class="inline-flex items-center gap-1 text-[--color-text-muted] hover:text-[--color-accent] transition-colors text-sm font-mono mb-4">
        &larr; {t('coins.back')}
      </a>

      <!-- Header -->
      <div class="mb-6">
        <h1 class="text-2xl md:text-3xl font-bold mb-2">{fullName} <span class="text-[--color-text-muted] font-normal text-lg">({displayName})</span></h1>
        <p class="text-[--color-text-muted] text-sm max-w-2xl">
          BB Squeeze SHORT strategy simulation for {fullName}. Analyze 2+ years of historical data with entry/exit signals, equity curve, and per-trade breakdown.
        </p>
      </div>

      <!-- Chart -->
      <div id="coin-mount" data-symbol={symbolUpper}>
        <div class="animate-pulse">
          <div class="h-64 bg-[--color-bg-hover] rounded mb-4"></div>
          <div class="h-4 bg-[--color-bg-hover] rounded w-1/3"></div>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <a href={`/simulate?coin=${symbolUpper}`}
           class="inline-flex items-center gap-2 bg-[--color-accent] text-[--color-bg] px-5 py-2.5 rounded font-semibold text-sm hover:bg-[--color-accent-dim]">
          Simulate {coinName} &rarr;
        </a>
        <a href="/strategies" class="text-sm text-[--color-text-muted] hover:text-[--color-accent]">All strategies</a>
        <a href="/coins" class="text-sm text-[--color-text-muted] hover:text-[--color-accent]">All coins</a>
      </div>

      <div id="exchange-cta-mount" data-coin={symbolUpper}></div>

      <!-- Strategy overview -->
      <div class="mt-10 border-t border-[--color-border] pt-8">
        <h2 class="text-lg font-bold mb-4">Strategy overview</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
          <div class="border border-[--color-border] rounded p-3 bg-[--color-bg-card]">
            <p class="text-xs text-[--color-text-muted] font-mono mb-1">DIRECTION</p>
            <p class="font-bold text-[--color-accent]">SHORT ONLY</p>
          </div>
          <div class="border border-[--color-border] rounded p-3 bg-[--color-bg-card]">
            <p class="text-xs text-[--color-text-muted] font-mono mb-1">STOP-LOSS / TAKE-PROFIT</p>
            <p class="font-bold">10% / 8%</p>
          </div>
          <div class="border border-[--color-border] rounded p-3 bg-[--color-bg-card]">
            <p class="text-xs text-[--color-text-muted] font-mono mb-1">MAX HOLD</p>
            <p class="font-bold">48 hours</p>
          </div>
          <div class="border border-[--color-border] rounded p-3 bg-[--color-bg-card]">
            <p class="text-xs text-[--color-text-muted] font-mono mb-1">DATA PERIOD</p>
            <p class="font-bold">2+ years (1H)</p>
          </div>
        </div>
        <p class="text-sm text-[--color-text-muted] leading-relaxed max-w-3xl">
          The BB Squeeze strategy identifies periods of low volatility (Bollinger Band compression) on {fullName}. When the bands expand and price breaks downward, a short position is entered. The strategy has been validated across 549 coins with out-of-sample testing and Monte Carlo simulation.
        </p>
      </div>

      <!-- FAQ -->
      <div class="mt-10 border-t border-[--color-border] pt-8">
        <h2 class="text-lg font-bold mb-4">FAQ</h2>
        <div class="space-y-4 max-w-3xl">
          <details class="border border-[--color-border] rounded bg-[--color-bg-card]">
            <summary class="px-4 py-3 cursor-pointer font-semibold text-sm hover:text-[--color-accent]">What is the BB Squeeze SHORT strategy for {fullName}?</summary>
            <p class="px-4 pb-3 text-sm text-[--color-text-muted]">The BB Squeeze SHORT strategy detects Bollinger Band compression on {displayName} and enters a short position when a downward breakout occurs. It uses a 10% stop-loss and 8% take-profit with up to 48-hour holding periods.</p>
          </details>
          <details class="border border-[--color-border] rounded bg-[--color-bg-card]">
            <summary class="px-4 py-3 cursor-pointer font-semibold text-sm hover:text-[--color-accent]">How reliable is the {fullName} backtest?</summary>
            <p class="px-4 pb-3 text-sm text-[--color-text-muted]">PRUVIQ backtests use 2+ years of 1-hour OHLCV data from Binance Futures. All results are out-of-sample tested with Monte Carlo validation (10,000 iterations). No look-ahead bias — only completed candles are used for signals.</p>
          </details>
          <details class="border border-[--color-border] rounded bg-[--color-bg-card]">
            <summary class="px-4 py-3 cursor-pointer font-semibold text-sm hover:text-[--color-accent]">Is it free to simulate {fullName}?</summary>
            <p class="px-4 pb-3 text-sm text-[--color-text-muted]">Yes. PRUVIQ is 100% free. You can simulate the BB Squeeze strategy on any supported coin, adjust parameters, and view detailed equity curves and trade logs — no account required.</p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { h, render } from 'preact';
    import CoinChart from '../../components/CoinChart';
    import ErrorBoundary from '../../components/ErrorBoundary';
    import ExchangeCTA from '../../components/ExchangeCTA';

    const mount = document.getElementById('coin-mount');
    if (mount) {
      const symbol = mount.dataset.symbol;
      render(h(ErrorBoundary, { name: 'Coin Chart' }, h(CoinChart, { symbol, lang: 'en' })), mount);
    }

    const ctaMount = document.getElementById('exchange-cta-mount');
    if (ctaMount) {
      const coin = ctaMount.dataset.coin;
      render(h(ExchangeCTA, { mode: 'card', lang: 'en', coin }), ctaMount);
    }
  </script>
</Layout>
