---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/index';

const t = useTranslations('en');

const allStrategies = await getCollection('strategies');

// Load all simulator presets for the "Try in Simulator" section (from static JSON)
import presetsJson from '../../../public/data/builder-presets.json';
const simulatorPresets: Array<{id: string; name_ko?: string; name?: string; direction?: string; timeframe?: string; description_ko?: string}> = presetsJson as Array<{id: string; name_ko?: string; name?: string; direction?: string; timeframe?: string; description_ko?: string}>;

const statusOrder = { verified: 0, testing: 1, killed: 2, shelved: 3 };
const strategies = allStrategies.sort((a, b) => statusOrder[a.data.status] - statusOrder[b.data.status]);

const statusColors: Record<string, string> = {
  verified: '--color-accent',
  testing: '--color-yellow',
  killed: '--color-red',
  shelved: '--color-text-muted',
};

const statusLabels: Record<string, string> = {
  verified: t('strategy.verified'),
  testing: t('strategy.testing'),
  killed: t('strategy.killed'),
  shelved: t('strategy.shelved'),
};

const categoryLabels: Record<string, string> = {
  'mean-reversion': t('strategy.mean_reversion'),
  'momentum': t('strategy.momentum'),
  'breakout': t('strategy.breakout'),
  'volatility': t('strategy.volatility'),
  'hybrid': t('strategy.hybrid'),
};

const difficultyLabels: Record<string, string> = {
  beginner: t('strategy.beginner'),
  intermediate: t('strategy.intermediate'),
  advanced: t('strategy.advanced'),
};

const difficultyColors: Record<string, string> = {
  beginner: '--color-accent',
  intermediate: '--color-yellow',
  advanced: '--color-red',
};
---

<Layout title={t('meta.strategies_title')} description={t('meta.strategies_desc')}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "PRUVIQ Strategy Library",
    "description": "Crypto trading strategies tested with real market data. Verified and killed — all results published.",
    "numberOfItems": strategies.length,
    "itemListElement": strategies.map((s, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": s.data.name,
      "url": `https://pruviq.com/strategies/${s.id}`
    }))
  })} />
  <section class="py-12">
    <div class="max-w-5xl mx-auto px-4">

      <!-- QW4: Tab navigation -->
      <nav class="flex gap-1 mb-8 border-b border-[--color-border]" aria-label="Strategy navigation">
        <a href="/strategies" aria-current="page" class="px-4 py-2.5 font-mono text-sm font-semibold text-[--color-accent] border-b-2 border-[--color-accent] -mb-px bg-[--color-accent-bg] transition-colors">
          {t('nav.strategies')}
        </a>
        <a href="/strategies/ranking" class="px-4 py-2.5 font-mono text-sm text-[--color-text-muted] border-b-2 border-transparent -mb-px hover:text-[--color-text] hover:border-[--color-border] transition-colors">
          {t('ranking.tag')}
        </a>
        <a href="/leaderboard" class="px-4 py-2.5 font-mono text-sm text-[--color-text-muted] border-b-2 border-transparent -mb-px hover:text-[--color-text] hover:border-[--color-border] transition-colors">
          {t('leaderboard.tag')}
        </a>
      </nav>

      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('strategies.tag')}</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">{t('strategies.title')}</h1>
      <p class="text-[--color-text-muted] text-lg mb-4 max-w-2xl">
        {t('strategies.desc')}
      </p>
      <p class="text-[--color-text-muted] text-sm mb-12 max-w-2xl">
        {t('strategies.count')
          .replace('{total}', String(strategies.length))
          .replace('{verified}', String(strategies.filter(s => s.data.status === 'verified').length))
          .replace('{killed}', String(strategies.filter(s => s.data.status === 'killed').length))
          .replace('{shelved}', String(strategies.filter(s => s.data.status === 'shelved').length))
        }
      </p>

      <p class="text-sm text-[--color-accent] font-mono mb-6 max-w-2xl border border-[--color-accent]/20 rounded-lg px-4 py-3 bg-[--color-accent]/5">
        {t('strategies.funnel')
          .replace('{total}', String(strategies.length))
          .replace('{verified}', String(strategies.filter(s => s.data.status === 'verified').length))
        }
      </p>

      <!-- Daily Ranking Banner -->
      <a href="/strategies/ranking" class="flex items-center justify-between gap-3 mb-6 border border-[--color-accent]/30 rounded-lg px-4 py-3 bg-[--color-accent]/5 hover:bg-[--color-accent]/10 transition-colors group">
        <div class="flex items-center gap-3">
          <span class="inline-block w-2 h-2 rounded-full bg-[--color-accent] animate-pulse shrink-0"></span>
          <div>
            <p class="font-semibold text-sm text-[--color-text]">📊 Daily Strategy Ranking</p>
            <p class="text-xs text-[--color-text-muted]">Today's best and worst strategies ranked by Profit Factor — updated daily</p>
          </div>
        </div>
        <span class="text-[--color-accent] text-sm font-semibold shrink-0 group-hover:translate-x-1 transition-transform">&rarr;</span>
      </a>

      <div class="mb-4 flex flex-col sm:flex-row gap-3">
        <a href="/simulate"
           class="btn-primary inline-flex items-center gap-2 bg-[--color-accent] text-[--color-bg] px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-[--color-accent-dim]">
          {t('hero.cta_builder')} &rarr;
        </a>
        <a href="/strategies/compare"
           class="inline-flex items-center gap-2 border border-[--color-border] text-[--color-text] px-5 py-2.5 rounded-lg font-semibold text-sm hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
          {t('strategies.compare')} &rarr;
        </a>
      </div>

      <div class="mb-8 border border-[--color-border] rounded-lg p-5 bg-[--color-bg-card] flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <div class="flex-1">
          <p class="font-mono text-[--color-accent] text-xs font-bold mb-1">{t('strategies.beginner_tag')}</p>
          <p class="text-[--color-text-muted] text-sm">{t('strategies.beginner_desc')}</p>
        </div>
        <a href="/learn"
           class="shrink-0 border border-[--color-accent] text-[--color-accent] px-5 py-2 rounded text-sm font-semibold hover:bg-[--color-accent] hover:text-[--color-bg] transition-colors whitespace-nowrap">
          {t('strategies.beginner_cta')} &rarr;
        </a>
      </div>

      <!-- Filter Bar -->
      <div class="mb-6 flex flex-wrap gap-4" id="strategy-filters">
        <div class="flex items-center gap-1.5 flex-wrap">
          <span class="font-mono text-xs text-[--color-text-muted] mr-1">Status:</span>
          <button data-filter-group="status" data-filter-value="all"
            class="font-mono text-xs border rounded px-3 py-1.5 transition-colors bg-[--color-accent] text-black border-[--color-accent]">
            All
          </button>
          <button data-filter-group="status" data-filter-value="verified"
            class="font-mono text-xs border border-[--color-border] rounded px-3 py-1.5 text-[--color-text-muted] hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
            Active
          </button>
          <button data-filter-group="status" data-filter-value="killed"
            class="font-mono text-xs border border-[--color-border] rounded px-3 py-1.5 text-[--color-text-muted] hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
            Retired
          </button>
        </div>
        <div class="flex items-center gap-1.5 flex-wrap">
          <span class="font-mono text-xs text-[--color-text-muted] mr-1">Direction:</span>
          <button data-filter-group="direction" data-filter-value="all"
            class="font-mono text-xs border rounded px-3 py-1.5 transition-colors bg-[--color-accent] text-black border-[--color-accent]">
            All
          </button>
          <button data-filter-group="direction" data-filter-value="long"
            class="font-mono text-xs border border-[--color-border] rounded px-3 py-1.5 text-[--color-text-muted] hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
            LONG
          </button>
          <button data-filter-group="direction" data-filter-value="short"
            class="font-mono text-xs border border-[--color-border] rounded px-3 py-1.5 text-[--color-text-muted] hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
            SHORT
          </button>
          <button data-filter-group="direction" data-filter-value="both"
            class="font-mono text-xs border border-[--color-border] rounded px-3 py-1.5 text-[--color-text-muted] hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
            BOTH
          </button>
        </div>
      </div>

      <div class="space-y-4" id="strategy-list">
        {strategies.map((strategy) => (
          <div class="block border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] hover:border-[--color-accent] transition-colors group"
               data-status={strategy.data.status}
               data-direction={strategy.data.direction.toLowerCase()}>
            <a href={`/strategies/${strategy.id}`} class="block">
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-3">
                <div class="flex items-center gap-3">
                  <span class="font-mono text-xs tracking-wider px-2 py-0.5 rounded border"
                        style={`color: var(${statusColors[strategy.data.status]}); border-color: var(${statusColors[strategy.data.status]})`}>
                    {statusLabels[strategy.data.status]}
                  </span>
                  <span class="text-[--color-text-muted] text-xs font-mono">
                    {categoryLabels[strategy.data.category]} &middot; {strategy.data.direction.toUpperCase()} &middot; {strategy.data.timeframe}
                  </span>
                </div>
                <span class="text-xs font-mono px-2 py-0.5 rounded border border-[--color-border]"
                      style={`color: var(${difficultyColors[strategy.data.difficulty]})`}>
                  {difficultyLabels[strategy.data.difficulty] || strategy.data.difficulty.toUpperCase()}
                </span>
              </div>

              <h2 class="text-xl font-bold mb-2 group-hover:text-[--color-accent] transition-colors">
                {strategy.data.name}
              </h2>
              <p class="text-[--color-text-muted] text-sm mb-4">{strategy.data.description}</p>

              {/* OOS validation status label */}
              {(strategy.data.status === 'testing' || strategy.data.status === 'shelved') && (
                <p class="font-mono text-[10px] text-[--color-yellow]/80 mb-3">&#9888; Not OOS-validated &mdash; research only</p>
              )}
              {strategy.data.status === 'verified' && (
                <p class="font-mono text-[10px] text-[--color-accent] mb-3">&#10003; OOS-validated</p>
              )}

              {(strategy.data.winRate || strategy.data.profitFactor || strategy.data.totalPnl) && (
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 font-mono text-sm">
                  {strategy.data.winRate !== undefined && (
                    <div>
                      <span class="text-[--color-text-muted] text-xs">{t('strategy.win_rate')}</span>
                      <p class={`font-bold ${strategy.data.winRate >= 55 ? 'text-[--color-accent]' : strategy.data.winRate >= 50 ? 'text-[--color-yellow]' : 'text-[--color-red]'}`}>
                        {strategy.data.winRate}%
                      </p>
                    </div>
                  )}
                  {strategy.data.profitFactor !== undefined && (
                    <div>
                      <span class="text-[--color-text-muted] text-xs">{t('strategy.profit_factor')}</span>
                      <p class={`font-bold ${strategy.data.profitFactor >= 1.5 ? 'text-[--color-accent]' : strategy.data.profitFactor >= 1.0 ? 'text-[--color-yellow]' : 'text-[--color-red]'}`}>
                        {strategy.data.profitFactor}
                      </p>
                    </div>
                  )}
                  {strategy.data.totalPnl && (
                    <div>
                      <span class="text-[--color-text-muted] text-xs">{t('strategy.total_pnl')}</span>
                      <p class={`font-bold ${strategy.data.totalPnl.startsWith('+') ? 'text-[--color-accent]' : 'text-[--color-red]'}`}>
                        {strategy.data.totalPnl}
                      </p>
                    </div>
                  )}
                  {strategy.data.coins !== undefined && (
                    <div>
                      <span class="text-[--color-text-muted] text-xs">{t('strategy.coins_tested')}</span>
                      <p class="font-bold">{strategy.data.coins}</p>
                    </div>
                  )}
                </div>
              )}
            </a>
            {strategy.data.status === 'verified' && (
              <div class="mt-4 pt-4 border-t border-[--color-border]/50 flex items-center justify-between">
                <span class="text-xs text-[--color-up] font-mono">{t('strategies.verified_explanation')}</span>
                <a href={`/simulate?preset=${strategy.id}`}
                   class="inline-flex items-center gap-1 bg-[--color-accent] text-[--color-bg] px-4 py-1.5 rounded font-semibold text-xs hover:bg-[--color-accent-dim]">
                  {t('strategies.simulate_button')} &rarr;
                </a>
              </div>
            )}
          </div>
        ))}
      </div>

      {simulatorPresets.length > 0 && (
        <div class="mt-12">
          <h2 class="text-xl font-bold mb-2">{t('strategies.presets_title').replace('{count}', String(simulatorPresets.length))}</h2>
          <p class="text-[--color-text-muted] text-sm mb-6">
            {t('strategies.presets_desc')}
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {simulatorPresets.map((preset) => (
              <a
                href={`/simulate?preset=${preset.id}`}
                class="flex items-center justify-between border border-[--color-border] rounded-lg px-4 py-3 bg-[--color-bg-card] hover:border-[--color-accent] hover:text-[--color-accent] transition-colors group"
              >
                <div>
                  <p class="font-semibold text-sm">{preset.name_ko ?? preset.name}</p>
                  {preset.description_ko && (
                    <p class="text-[--color-text-muted] text-xs mt-0.5 line-clamp-1">{preset.description_ko}</p>
                  )}
                </div>
                <div class="flex items-center gap-2 shrink-0 ml-3">
                  {preset.direction && (
                    <span class={`font-mono text-xs px-1.5 py-0.5 rounded border ${preset.direction === 'long' ? 'text-[--color-accent] border-[--color-accent]/30' : preset.direction === 'short' ? 'text-[--color-red] border-[--color-red]/30' : 'text-[--color-yellow] border-[--color-yellow]/30'}`}>
                      {preset.direction.toUpperCase()}
                    </span>
                  )}
                  <span class="text-[--color-text-muted] text-xs group-hover:text-[--color-accent]">&rarr;</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="mt-12 border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] text-center">
        <p class="font-mono text-[--color-accent] text-sm mb-2">{t('strategies.more_tag')}</p>
        <p class="text-[--color-text-muted] text-sm mb-4">
          {t('strategies.more_desc')}
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/performance" class="inline-block border border-[--color-border] px-5 py-2 rounded font-semibold text-sm hover:border-[--color-accent] transition-colors no-underline">
            {t('strategies.performance_cta')} &rarr;
          </a>
          <a href="/fees" class="inline-block border border-[--color-border] px-5 py-2 rounded font-semibold text-sm hover:border-[--color-accent] transition-colors no-underline">
            {t('strategies.fees_cta')} &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  (function () {
    const activeStatus = { status: 'all', direction: 'all' };

    const accentColor = 'var(--color-accent, #00ff88)';
    const mutedBorder = 'var(--color-border, #333)';
    const mutedText = 'var(--color-text-muted, #888)';

    function applyFilters() {
      const cards = document.querySelectorAll<HTMLElement>('#strategy-list > [data-status]');
      cards.forEach((card) => {
        const statusMatch =
          activeStatus.status === 'all' || card.dataset.status === activeStatus.status;
        const directionMatch =
          activeStatus.direction === 'all' || card.dataset.direction === activeStatus.direction;
        card.style.display = statusMatch && directionMatch ? '' : 'none';
      });
    }

    function updateButtons(group: string, value: string) {
      const buttons = document.querySelectorAll<HTMLButtonElement>(
        `[data-filter-group="${group}"]`
      );
      buttons.forEach((btn) => {
        const isActive = btn.dataset.filterValue === value;
        btn.style.backgroundColor = isActive ? accentColor : '';
        btn.style.color = isActive ? 'black' : mutedText;
        btn.style.borderColor = isActive ? accentColor : mutedBorder;
      });
    }

    document.querySelectorAll<HTMLButtonElement>('[data-filter-group]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const group = btn.dataset.filterGroup as 'status' | 'direction';
        const value = btn.dataset.filterValue!;
        activeStatus[group] = value;
        updateButtons(group, value);
        applyFilters();
      });
    });
  })();
</script>
