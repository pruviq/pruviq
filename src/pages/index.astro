          </div>
          <div class="flex justify-between border-b border-[--color-border] pb-2 sm:border-0">
            <span class="text-[--color-text-muted]">AI Analysis</span>
            <span>Local LLM (M4)</span>
          </div>
          <div class="flex justify-between border-b border-[--color-border] pb-2 sm:border-0">
            <span class="text-[--color-text-muted]">Backtesting</span>
            <span>Custom Engine</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[--color-text-muted]">Alerts</span>
