---
import Layout from '../layouts/Layout.astro';
import DemoRunner from '../components/DemoRunner';
---

<Layout title="PRUVIQ Demo">
  <section class="max-w-6xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-4">Live Demo</h1>
    <p class="text-[--color-text-muted] mb-6">Try a quick demo run of our simulator. This loads a precomputed demo result (PoC) so you can experience the flow instantly.</p>

    <DemoRunner client:idle />

  </section>
</Layout>
