---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/index';
import { getCollection } from 'astro:content';
import LiveStats from '../components/LiveStats';

const t = useTranslations('en');
const allStrategies = await getCollection('strategies');
const verifiedCount = allStrategies.filter(s => s.data.status === 'verified').length;
const lastUpdated = new Date().toLocaleDateString('en-US');
---

<Layout title={t('meta.home_title')} description={t('meta.index_desc')}>

  <!-- HERO -->
  <section class="min-h-[80vh] flex items-center" aria-labelledby="hero-heading">
    <div class="max-w-6xl mx-auto px-4 py-20">
      <div class="max-w-3xl">
        <p class="font-mono text-[--color-accent] text-sm mb-4 tracking-wider">{t('hero.tag')}</p>
        <h1 id="hero-heading" class="text-4xl md:text-6xl font-bold leading-tight mb-6">
          {t('hero.title1')}<br/>
          <span class="text-[--color-accent]">{t('hero.title2')}</span>
        </h1>
        <p class="text-lg text-[--color-text-muted] mb-2 font-mono">
          {t('hero.subtitle')}
        </p>
        <p class="text-lg md:text-xl text-[--color-text-muted] mb-4 max-w-2xl">
          {t('hero.desc')}
        </p>
        <!-- Live Trading Proof Bar -->
        <div class="flex flex-wrap gap-3 mb-4 font-mono text-sm">
          <span class="px-3 py-1.5 rounded bg-green-500/10 text-green-400 border border-green-500/20">{t('hero.live_trades')}</span>
          <span class="px-3 py-1.5 rounded bg-[--color-accent]/10 text-[--color-accent] border border-[--color-accent]/20">{t('hero.live_wr')}</span>
          <span class="px-3 py-1.5 rounded bg-[--color-accent]/10 text-[--color-accent] border border-[--color-accent]/20">{t('hero.live_days')}</span>
          <span class="px-3 py-1.5 rounded bg-[--color-accent]/10 text-[--color-accent] border border-[--color-accent]/20">{t('hero.live_capital')}</span>
        </div>

        <p class="text-sm text-[--color-text-muted] mb-8 max-w-2xl opacity-70">
          {t('hero.beginner_note')}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-4">
          <a href="/simulate"
             class="btn-primary bg-[--color-accent] text-[--color-bg] px-8 py-3 rounded font-semibold text-center hover:bg-[--color-accent-dim] min-h-[44px] text-lg">
            {t('hero.cta_primary')} &rarr;
          </a>
          <a href="/strategies"
             class="border border-[--color-border] text-[--color-text] px-8 py-3 rounded font-semibold text-center hover:border-[--color-accent] hover:text-[--color-accent] transition-colors min-h-[44px] text-lg">
            {t('hero.cta1')}
          </a>
        </div>
        <!-- Trust signals -->
        <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-[--color-text-muted] font-mono mb-4">
          <span>Binance API Read-Only</span>
          <span>Open Source</span>
          <span>No Personal Data</span>
          <span>Monte Carlo Validated</span>
        </div>
        <a href="/compare/tradingview" class="text-xs text-[--color-accent] hover:underline font-mono mb-8 inline-block">Why traders switch from TradingView &rarr;</a>

        <!-- Stats -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card] card-hover">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">549</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat1')}</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card] card-hover">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">2,898+</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat4')}</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card] card-hover">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">9.4M+</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat5')}</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card] card-hover">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">{t('hero.stat2_val')}</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat2')}</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card] card-hover">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">100%</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat3')}</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card] card-hover">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">$0</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat6')}</p>
          </div>
        </div>

        <!-- TRUST BLOCK -->
        <div class="mt-6 border border-[--color-border] rounded p-4 bg-[--color-bg-card] flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <p class="text-sm font-mono text-[--color-text-muted]">Verified strategies</p>
            <p class="text-xl font-bold text-[--color-accent]">{verifiedCount} verified</p>
            <p class="text-xs text-[--color-text-muted]">Last updated: {lastUpdated}</p>
          </div>
          <div class="sm:text-right">
            <a href="/simulate" class="inline-block bg-[--color-accent] text-[--color-bg] px-4 py-2 rounded font-semibold text-sm hover:bg-[--color-accent-dim]">{t('cta.button1')}</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- PROBLEM (PAS Framework - Agitate) -->
  <section class="py-20 border-t border-[--color-border] bg-[--color-bg-subtle]" aria-labelledby="problem-heading">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-red-400 text-sm mb-2 tracking-wider">{t('problem.tag')}</p>
      <h2 id="problem-heading" class="text-3xl md:text-4xl font-bold mb-12">{t('problem.title')}</h2>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <div class="border border-red-500/30 rounded-lg p-6 bg-[--color-bg-card]">
          <div class="text-red-400 font-mono text-xs font-bold mb-3 flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full bg-red-400"></span>
            CASE STUDY #1
          </div>
          <h3 class="font-bold text-lg mb-2">{t('problem.card1_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed mb-3">{t('problem.card1_desc')}</p>
          <p class="text-xs text-[--color-text-muted] opacity-60 italic">{t('problem.card1_source')}</p>
        </div>
        <div class="border border-red-500/30 rounded-lg p-6 bg-[--color-bg-card]">
          <div class="text-red-400 font-mono text-xs font-bold mb-3 flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full bg-red-400"></span>
            CASE STUDY #2
          </div>
          <h3 class="font-bold text-lg mb-2">{t('problem.card2_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed mb-3">{t('problem.card2_desc')}</p>
          <p class="text-xs text-[--color-text-muted] opacity-60 italic">{t('problem.card2_source')}</p>
        </div>
        <div class="border border-red-500/30 rounded-lg p-6 bg-[--color-bg-card]">
          <div class="text-red-400 font-mono text-xs font-bold mb-3 flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full bg-red-400"></span>
            CASE STUDY #3
          </div>
          <h3 class="font-bold text-lg mb-2">{t('problem.card3_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed mb-3">{t('problem.card3_desc')}</p>
          <p class="text-xs text-[--color-text-muted] opacity-60 italic">{t('problem.card3_source')}</p>
        </div>
      </div>

      <div class="text-center">
        <p class="text-xl md:text-2xl font-bold">
          {t('problem.hook')} <span class="text-[--color-accent]">{t('problem.hook_accent')}</span>
        </p>
      </div>
    </div>
  </section>

  <!-- EVIDENCE (PAS Framework - Solution Proof) -->
  <section class="py-20 border-t border-[--color-border]" aria-labelledby="evidence-heading">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('evidence.tag')}</p>
      <h2 id="evidence-heading" class="text-3xl md:text-4xl font-bold mb-4">{t('evidence.title')}</h2>
      <p class="text-[--color-text-muted] text-lg mb-12 max-w-3xl">{t('evidence.desc')}</p>

      <div class="grid md:grid-cols-2 gap-8 mb-16">
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
          <div class="font-mono text-[--color-accent] text-xs font-bold mb-3">STEP 01</div>
          <h3 class="font-bold text-lg mb-2">{t('evidence.step1_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('evidence.step1_desc')}</p>
        </div>
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
          <div class="font-mono text-[--color-accent] text-xs font-bold mb-3">STEP 02</div>
          <h3 class="font-bold text-lg mb-2">{t('evidence.step2_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('evidence.step2_desc')}</p>
        </div>
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
          <div class="font-mono text-[--color-accent] text-xs font-bold mb-3">STEP 03</div>
          <h3 class="font-bold text-lg mb-2">{t('evidence.step3_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('evidence.step3_desc')}</p>
        </div>
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
          <div class="font-mono text-[--color-accent] text-xs font-bold mb-3">STEP 04</div>
          <h3 class="font-bold text-lg mb-2">{t('evidence.step4_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('evidence.step4_desc')}</p>
        </div>
      </div>

      <!-- The Elimination Process -->
      <div class="border border-[--color-accent]/30 rounded-lg p-8 bg-[--color-bg-card] max-w-3xl mx-auto mb-12">
        <p class="font-mono text-[--color-accent] text-xs font-bold mb-4">{t('evidence.lesson_tag')}</p>
        <p class="text-[--color-text-muted] leading-relaxed mb-3">
          {t('evidence.lesson1')} <span class="text-[--color-accent] font-bold text-lg">{t('evidence.lesson_loss')}</span> <span class="text-green-400 font-bold text-lg">{t('evidence.lesson1_end')}</span>
        </p>
        <p class="text-[--color-text-muted] leading-relaxed mb-3">{t('evidence.lesson2')}</p>
        <p class="text-[--color-text-muted] leading-relaxed mb-4">{t('evidence.lesson3')}</p>
        <p class="text-[--color-accent] font-bold text-lg italic">{t('evidence.lesson_rule')}</p>
      </div>

      <!-- What we publish vs don't promise -->
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="border border-green-500/30 rounded-lg p-6 bg-[--color-bg-card]">
          <p class="font-mono text-green-400 text-xs font-bold mb-4">{t('evidence.publish_tag')}</p>
          <ul class="space-y-2 text-sm text-[--color-text-muted]">
            <li class="flex items-start gap-2"><span class="text-green-400 shrink-0 mt-0.5">&#10003;</span> {t('evidence.publish1')}</li>
            <li class="flex items-start gap-2"><span class="text-green-400 shrink-0 mt-0.5">&#10003;</span> {t('evidence.publish2')}</li>
            <li class="flex items-start gap-2"><span class="text-green-400 shrink-0 mt-0.5">&#10003;</span> {t('evidence.publish3')}</li>
            <li class="flex items-start gap-2"><span class="text-green-400 shrink-0 mt-0.5">&#10003;</span> {t('evidence.publish4')}</li>
            <li class="flex items-start gap-2"><span class="text-green-400 shrink-0 mt-0.5">&#10003;</span> {t('evidence.publish5')}</li>
          </ul>
        </div>
        <div class="border border-red-500/30 rounded-lg p-6 bg-[--color-bg-card]">
          <p class="font-mono text-red-400 text-xs font-bold mb-4">{t('evidence.nopromise_tag')}</p>
          <ul class="space-y-2 text-sm text-[--color-text-muted]">
            <li class="flex items-start gap-2"><span class="text-red-400 shrink-0 mt-0.5">&#10007;</span> {t('evidence.nopromise1')}</li>
            <li class="flex items-start gap-2"><span class="text-red-400 shrink-0 mt-0.5">&#10007;</span> {t('evidence.nopromise2')}</li>
            <li class="flex items-start gap-2"><span class="text-red-400 shrink-0 mt-0.5">&#10007;</span> {t('evidence.nopromise3')}</li>
            <li class="flex items-start gap-2"><span class="text-red-400 shrink-0 mt-0.5">&#10007;</span> {t('evidence.nopromise4')}</li>
            <li class="flex items-start gap-2"><span class="text-red-400 shrink-0 mt-0.5">&#10007;</span> {t('evidence.nopromise5')}</li>
          </ul>
        </div>
      </div>

      <div class="text-center">
        <a href="/demo" class="inline-block bg-[--color-accent] text-[--color-bg] px-8 py-3 rounded font-semibold text-lg hover:bg-[--color-accent-dim]">
          {t('evidence.try_cta')} &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- SYSTEM (How It Works - Visual) -->
  <section class="py-20 border-t border-[--color-border] bg-[--color-bg-subtle]" aria-labelledby="system-heading">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('system.tag')}</p>
      <h2 id="system-heading" class="text-3xl md:text-4xl font-bold mb-4">{t('system.title')}</h2>
      <p class="text-[--color-text-muted] text-lg mb-12 max-w-2xl">{t('system.desc')}</p>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <div class="relative">
          <div class="font-mono text-[--color-accent] text-5xl font-bold opacity-20 absolute -top-4 -left-2">1</div>
          <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] relative">
            <h3 class="font-mono text-[--color-accent] font-bold mb-2">{t('system.step1')}</h3>
            <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('system.step1_desc')}</p>
          </div>
          <div class="hidden md:block absolute top-1/2 -right-4 text-[--color-text-muted] text-2xl">&rarr;</div>
        </div>
        <div class="relative">
          <div class="font-mono text-[--color-accent] text-5xl font-bold opacity-20 absolute -top-4 -left-2">2</div>
          <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] relative">
            <h3 class="font-mono text-[--color-accent] font-bold mb-2">{t('system.step2')}</h3>
            <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('system.step2_desc')}</p>
          </div>
          <div class="hidden md:block absolute top-1/2 -right-4 text-[--color-text-muted] text-2xl">&rarr;</div>
        </div>
        <div class="relative">
          <div class="font-mono text-[--color-accent] text-5xl font-bold opacity-20 absolute -top-4 -left-2">3</div>
          <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] relative">
            <h3 class="font-mono text-[--color-accent] font-bold mb-2">{t('system.step3')}</h3>
            <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('system.step3_desc')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPARISON TABLE (vs Competitors) -->
  <section class="py-20 border-t border-[--color-border]" aria-labelledby="compare-heading">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('compare_table.tag')}</p>
      <h2 id="compare-heading" class="text-3xl md:text-4xl font-bold mb-12">{t('compare_table.title')}</h2>

      <div class="overflow-x-auto" role="region" aria-label="Platform comparison table" tabindex="0">
        <table class="w-full text-sm border-collapse" role="table" aria-label="PRUVIQ vs TradingView vs QuantConnect feature comparison">
          <thead>
            <tr class="border-b border-[--color-border]">
              <th scope="col" class="text-left py-3 px-4 font-mono text-[--color-text-muted] text-xs">{t('compare_table.feature')}</th>
              <th scope="col" class="text-center py-3 px-4 font-mono text-[--color-accent] text-xs bg-[--color-accent]/5">PRUVIQ</th>
              <th scope="col" class="text-center py-3 px-4 font-mono text-[--color-text-muted] text-xs">TradingView</th>
              <th scope="col" class="text-center py-3 px-4 font-mono text-[--color-text-muted] text-xs">QuantConnect</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-[--color-border]/50">
              <td class="py-3 px-4">No-code strategy builder</td>
              <td class="py-3 px-4 text-center text-green-400 bg-[--color-accent]/5">&#10003;</td>
              <td class="py-3 px-4 text-center text-red-400">&#10007; Pine Script</td>
              <td class="py-3 px-4 text-center text-red-400">&#10007; Python/C#</td>
            </tr>
            <tr class="border-b border-[--color-border]/50">
              <td class="py-3 px-4">549+ coins simultaneously</td>
              <td class="py-3 px-4 text-center text-green-400 bg-[--color-accent]/5">&#10003;</td>
              <td class="py-3 px-4 text-center text-red-400">&#10007; 1 at a time</td>
              <td class="py-3 px-4 text-center text-yellow-400">Limited</td>
            </tr>
            <tr class="border-b border-[--color-border]/50">
              <td class="py-3 px-4">Publishes failures</td>
              <td class="py-3 px-4 text-center text-green-400 bg-[--color-accent]/5">&#10003;</td>
              <td class="py-3 px-4 text-center text-red-400">&#10007;</td>
              <td class="py-3 px-4 text-center text-red-400">&#10007;</td>
            </tr>
            <tr class="border-b border-[--color-border]/50">
              <td class="py-3 px-4">Real trading verification</td>
              <td class="py-3 px-4 text-center text-green-400 bg-[--color-accent]/5">&#10003; Live</td>
              <td class="py-3 px-4 text-center text-red-400">&#10007;</td>
              <td class="py-3 px-4 text-center text-yellow-400">Paper only</td>
            </tr>
            <tr class="border-b border-[--color-border]/50">
              <td class="py-3 px-4">Realistic fees & slippage</td>
              <td class="py-3 px-4 text-center text-green-400 bg-[--color-accent]/5">&#10003;</td>
              <td class="py-3 px-4 text-center text-yellow-400">Basic</td>
              <td class="py-3 px-4 text-center text-green-400">&#10003;</td>
            </tr>
            <tr class="border-b border-[--color-border]/50">
              <td class="py-3 px-4">Free tier</td>
              <td class="py-3 px-4 text-center text-green-400 bg-[--color-accent]/5">100% Free</td>
              <td class="py-3 px-4 text-center text-yellow-400">$14.95/mo+</td>
              <td class="py-3 px-4 text-center text-yellow-400">Limited</td>
            </tr>
            <tr>
              <td class="py-3 px-4">No account required</td>
              <td class="py-3 px-4 text-center text-green-400 bg-[--color-accent]/5">&#10003;</td>
              <td class="py-3 px-4 text-center text-red-400">&#10007;</td>
              <td class="py-3 px-4 text-center text-red-400">&#10007;</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="mt-8 text-center">
        <a href="/compare/tradingview" class="text-sm text-[--color-accent] hover:underline">{t('compare_table.detail_link')} &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="py-20 border-t border-[--color-border] bg-[--color-bg-subtle]" aria-labelledby="features-heading">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('features.tag')}</p>
      <h2 id="features-heading" class="text-3xl md:text-4xl font-bold mb-12">{t('features.title')}</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <a href="/simulate" class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] card-hover block group">
          <p class="font-mono text-[--color-accent] text-xs font-bold mb-3">{t('features.card1_tag')}</p>
          <h3 class="font-bold text-lg mb-2 group-hover:text-[--color-accent] transition-colors">{t('features.card1_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('features.card1_desc')}</p>
        </a>
        <a href="/strategies" class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] card-hover block group">
          <p class="font-mono text-[--color-accent] text-xs font-bold mb-3">{t('features.card2_tag')}</p>
          <h3 class="font-bold text-lg mb-2 group-hover:text-[--color-accent] transition-colors">{t('features.card2_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('features.card2_desc')}</p>
        </a>
        <a href="/fees" class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] card-hover block group">
          <p class="font-mono text-[--color-accent] text-xs font-bold mb-3">{t('features.card3_tag')}</p>
          <h3 class="font-bold text-lg mb-2 group-hover:text-[--color-accent] transition-colors">{t('features.card3_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('features.card3_desc')}</p>
        </a>
      </div>
    </div>
