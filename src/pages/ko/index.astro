---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/index';
import { getCollection } from 'astro:content';

const t = useTranslations('ko');
const allStrategies = await getCollection('strategies');
const verifiedCount = allStrategies.filter(s => s.data.status === 'verified').length;
---

<Layout title={t('meta.home_title')}>

  <!-- HERO -->
  <section class="min-h-[80vh] flex items-center">
    <div class="max-w-6xl mx-auto px-4 py-20">
      <div class="max-w-3xl">
        <p class="font-mono text-[--color-accent] text-sm mb-4 tracking-wider">{t('hero.tag')}</p>
        <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6">
          {t('hero.title1')}<br/>
          <span class="text-[--color-accent]">{t('hero.title2')}</span>
        </h1>
        <p class="text-lg text-[--color-text-muted] mb-2 font-mono">
          {t('hero.subtitle')}
        </p>
        <p class="text-lg md:text-xl text-[--color-text-muted] mb-4 max-w-2xl">
          {t('hero.desc')}
        </p>
        <p class="text-sm text-[--color-text-muted] mb-8 max-w-2xl opacity-70">
          {t('hero.beginner_note')}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="/ko/simulate"
             class="btn-primary bg-[--color-accent] text-[--color-bg] px-8 py-3 rounded font-semibold text-center hover:bg-[--color-accent-dim]">
            {t('hero.cta_primary')} &rarr;
          </a>
          <a href="/ko/strategies"
             class="border border-[--color-border] text-[--color-text] px-8 py-3 rounded font-semibold text-center hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
            {t('hero.cta1')}
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card] card-hover">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">535</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat1')}</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card] card-hover">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">2,898+</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat4')}</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card] card-hover">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">9.4M+</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat5')}</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card] card-hover">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">{t('hero.stat2_val')}</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat2')}</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card] card-hover">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">100%</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat3')}</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card] card-hover">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">$0</p>
            <p class="text-[--color-text-muted] text-sm">{t('hero.stat6')}</p>
          </div>
        </div>

        <!-- TRUST BLOCK -->
        <div class="mt-6 border border-[--color-border] rounded p-4 bg-[--color-bg-card] flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <p class="text-sm font-mono text-[--color-text-muted]">{t('simulate.strategies_title')}</p>
            <p class="text-xl font-bold text-[--color-accent]">{verifiedCount}개 {t('strategy.verified')}</p>
          </div>
          <div class="sm:text-right">
            <a href="/ko/simulate" class="inline-block bg-[--color-accent] text-[--color-bg] px-4 py-2 rounded font-semibold text-sm hover:bg-[--color-accent-dim]">{t('cta.button1')}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="py-20 border-t border-[--color-border] bg-[--color-bg-subtle]">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('features.tag')}</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-12">{t('features.title')}</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <a href="/ko/simulate" class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] card-hover block group">
          <p class="font-mono text-[--color-accent] text-xs font-bold mb-3">{t('features.card1_tag')}</p>
          <h3 class="font-bold text-lg mb-2 group-hover:text-[--color-accent] transition-colors">{t('features.card1_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('features.card1_desc')}</p>
        </a>
        <a href="/ko/strategies" class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] card-hover block group">
          <p class="font-mono text-[--color-accent] text-xs font-bold mb-3">{t('features.card2_tag')}</p>
          <h3 class="font-bold text-lg mb-2 group-hover:text-[--color-accent] transition-colors">{t('features.card2_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('features.card2_desc')}</p>
        </a>
        <a href="/ko/fees" class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] card-hover block group">
          <p class="font-mono text-[--color-accent] text-xs font-bold mb-3">{t('features.card3_tag')}</p>
          <h3 class="font-bold text-lg mb-2 group-hover:text-[--color-accent] transition-colors">{t('features.card3_title')}</h3>
          <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('features.card3_desc')}</p>
        </a>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-20 border-t border-[--color-border]">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('how.tag')}</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-12">{t('how.title')}</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="flex gap-4">
          <div class="font-mono text-[--color-accent] text-3xl font-bold shrink-0 w-12">01</div>
          <div>
            <h3 class="font-bold text-lg mb-2">{t('how.step1')}</h3>
            <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('how.step1_desc')}</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="font-mono text-[--color-accent] text-3xl font-bold shrink-0 w-12">02</div>
          <div>
            <h3 class="font-bold text-lg mb-2">{t('how.step2')}</h3>
            <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('how.step2_desc')}</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="font-mono text-[--color-accent] text-3xl font-bold shrink-0 w-12">03</div>
          <div>
            <h3 class="font-bold text-lg mb-2">{t('how.step3')}</h3>
            <p class="text-[--color-text-muted] text-sm leading-relaxed">{t('how.step3_desc')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST / SOCIAL PROOF -->
  <section class="py-20 border-t border-[--color-border] bg-[--color-bg-subtle]">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('trust.section_tag')}</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-12">{t('trust.section_title')}</h2>

      <!-- Stats row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
        <div class="text-center p-4">
          <p class="font-mono text-[--color-accent] text-3xl md:text-4xl font-bold">2,898</p>
          <p class="text-[--color-text-muted] text-sm mt-1">{t('trust.stat_trades')}</p>
        </div>
        <div class="text-center p-4">
          <p class="font-mono text-[--color-accent] text-3xl md:text-4xl font-bold">9.4M+</p>
          <p class="text-[--color-text-muted] text-sm mt-1">{t('trust.stat_datapoints')}</p>
        </div>
        <div class="text-center p-4">
          <p class="font-mono text-[--color-accent] text-3xl md:text-4xl font-bold">40+</p>
          <p class="text-[--color-text-muted] text-sm mt-1">{t('trust.stat_live_days')}</p>
        </div>
        <div class="text-center p-4">
          <p class="font-mono text-[--color-accent] text-3xl md:text-4xl font-bold">5</p>
          <p class="text-[--color-text-muted] text-sm mt-1">{t('trust.stat_strategies')}</p>
        </div>
      </div>

      <!-- Verification badges -->
      <div class="grid md:grid-cols-2 gap-6">
        <a href="/ko/methodology" class="border border-[--color-border] rounded-lg p-5 bg-[--color-bg-card] card-hover block group">
          <div class="flex items-center gap-3 mb-2">
            <span class="inline-flex items-center justify-center w-8 h-8 rounded bg-[--color-accent]/10 text-[--color-accent] font-mono text-sm font-bold shrink-0">MC</span>
            <h3 class="font-bold group-hover:text-[--color-accent] transition-colors">{t('trust.badge_mc')}</h3>
          </div>
          <p class="text-[--color-text-muted] text-sm">{t('trust.badge_mc_desc')}</p>
        </a>
        <a href="/ko/methodology" class="border border-[--color-border] rounded-lg p-5 bg-[--color-bg-card] card-hover block group">
          <div class="flex items-center gap-3 mb-2">
            <span class="inline-flex items-center justify-center w-8 h-8 rounded bg-[--color-accent]/10 text-[--color-accent] font-mono text-sm font-bold shrink-0">OOS</span>
            <h3 class="font-bold group-hover:text-[--color-accent] transition-colors">{t('trust.badge_oos')}</h3>
          </div>
          <p class="text-[--color-text-muted] text-sm">{t('trust.badge_oos_desc')}</p>
        </a>
        <a href="/ko/strategies/bb-squeeze-short" class="border border-[--color-border] rounded-lg p-5 bg-[--color-bg-card] card-hover block group">
          <div class="flex items-center gap-3 mb-2">
            <span class="inline-flex items-center justify-center w-8 h-8 rounded bg-green-500/10 text-green-400 font-mono text-xs font-bold shrink-0">LIVE</span>
            <h3 class="font-bold group-hover:text-[--color-accent] transition-colors">{t('trust.badge_live')}</h3>
          </div>
          <p class="text-[--color-text-muted] text-sm">{t('trust.badge_live_desc')}</p>
        </a>
        <a href="/ko/api" class="border border-[--color-border] rounded-lg p-5 bg-[--color-bg-card] card-hover block group">
          <div class="flex items-center gap-3 mb-2">
            <span class="inline-flex items-center justify-center w-8 h-8 rounded bg-[--color-accent]/10 text-[--color-accent] font-mono text-xs font-bold shrink-0">&lt;/&gt;</span>
            <h3 class="font-bold group-hover:text-[--color-accent] transition-colors">{t('trust.badge_open')}</h3>
          </div>
          <p class="text-[--color-text-muted] text-sm">{t('trust.badge_open_desc')}</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 border-t border-[--color-border]">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <p class="font-mono text-[--color-text-muted] text-sm mb-4 tracking-wider">{t('cta.tag')}</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        <span class="text-[--color-accent]">{t('cta.title')}</span>
      </h2>
      <p class="text-[--color-text-muted] text-lg mb-4 max-w-xl mx-auto">{t('cta.desc1')}</p>
      <p class="text-[--color-text-muted] text-sm mb-8 max-w-md mx-auto">{t('cta.desc2')}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-4">
        <a href="/ko/simulate"
           class="btn-primary inline-block bg-[--color-accent] text-[--color-bg] px-8 py-3 rounded font-semibold text-lg hover:bg-[--color-accent-dim]">
          {t('cta.button1')} &rarr;
        </a>
        <a href="/ko/strategies"
           class="inline-block border border-[--color-border] text-[--color-text] px-8 py-3 rounded font-semibold text-lg hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
          {t('hero.cta1')}
        </a>
      </div>
      <p class="text-[--color-text-muted] text-xs mt-6 max-w-lg mx-auto">{t('cta.disclaimer')}</p>
    </div>
  </section>

</Layout>
